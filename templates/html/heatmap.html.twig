{% include 'html/navigation/breadcrumbs.html.twig' with {'breadcrumbs': [{
    'url': 'heatmap',
    'label': 'Heatmap'|trans
}]} %}
{% autoescape false %}
    <div class="grid grid-cols-1 gap-y-2 heatmap-wrapper relative">
        <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs">
            <form class="flex flex-col gap-y-2 mb-2" autocomplete="off">
                <div class="flex flex-wrap gap-2">
                    {% if sportTypes|length > 0 %}
                        <div class="filter-dropdown">
                            <button id="dropdownSportTypesButton"
                                    data-dropdown="dropdownSportTypes" data-dropdown-offset-distance="10" data-dropdown-offset-skidding="0" type="button">
                                <span>{{ "Filter on sport type"|trans }}</span>
                                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
                                </svg>
                            </button>
                            <div id="dropdownSportTypes" class="divide-y divide-gray-100">
                                <ul class="space-y-1" aria-labelledby="dropdownSportTypesButton">
                                    {% for sportType in sportTypes %}
                                        <li>
                                            <div>
                                                <input type="checkbox" id="{{ sportType.value }}" data-dataTable-filter="sportType" name="sportType[{{ sportType.value }}]" value="{{ sportType.value }}" class="peer" />
                                                <label for="{{ sportType.value }}" class="flex gap-x-1 items-center">
                                                    {{ svgSportType(sportType) }}
                                                    <div>{{ sportType|trans }}</div>
                                                </label>
                                                <a href="#" data-datatable-filter-clear="sportType[{{ sportType.value }}]">{{ "clear"|trans }}</a>
                                            </div>
                                        </li>
                                    {% endfor %}
                                </ul>
                            </div>
                        </div>
                    {% endif %}
                    <div class="filter-dropdown">
                        <button id="dropdownDateRangeButton"
                                data-dropdown="dropdownDateRange" type="button">
                            <span>{{ "Date"|trans }}</span>
                            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
                            </svg>
                        </button>
                        <div id="dropdownDateRange" class="divide-y divide-gray-100">
                            <div class="flex items-center gap-x-2 p-3" aria-labelledby="dropdownDateRangeButton">
                                <div class="flex items-center" data-dataTable-filter="start-date[]">
                                    <input name="start-date[from]" type="date" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5">
                                    <span class="mx-2 text-gray-500">{{ "to"|trans }}</span>
                                    <input name="start-date[to]" type="date" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5">
                                </div>
                                <a href="#" class="text-primary text-sm text-right underline" data-dataTable-filter-clear="start-date">{{ "clear"|trans }}</a>
                            </div>
                            <div class="hidden lg:flex flex-wrap gap-1.5 p-3" data-date-preset-filter="start-date">
                                <a href="#" data-date-preset="this-week" class="text-xs text-gray-500 hover:text-primary border border-gray-200 hover:border-primary rounded-full px-2.5 py-1">{{ "This week"|trans }}</a>
                                <a href="#" data-date-preset="last-week" class="text-xs text-gray-500 hover:text-primary border border-gray-200 hover:border-primary rounded-full px-2.5 py-1">{{ "Last week"|trans }}</a>
                                <a href="#" data-date-preset="this-month" class="text-xs text-gray-500 hover:text-primary border border-gray-200 hover:border-primary rounded-full px-2.5 py-1">{{ "This month"|trans }}</a>
                                <a href="#" data-date-preset="last-month" class="text-xs text-gray-500 hover:text-primary border border-gray-200 hover:border-primary rounded-full px-2.5 py-1">{{ "Last month"|trans }}</a>
                                <a href="#" data-date-preset="last-30-days" class="text-xs text-gray-500 hover:text-primary border border-gray-200 hover:border-primary rounded-full px-2.5 py-1">{{ "Last 30 days"|trans }}</a>
                            </div>
                        </div>
                    </div>
                    <div class="filter-dropdown">
                        <button id="otherButton" data-dropdown="dropdownOther" data-dropdown-offset-distance="10" data-dropdown-offset-skidding="0" type="button">
                            <span>{{ "Other"|trans }}</span>
                            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
                            </svg>
                        </button>
                        <div id="dropdownOther">
                            <div class="px-1 py-2 flex gap-x-2 divide-x divide-gray-100">
                                <div class="flex flex-col items-center">
                                    <div class="text-xs font-medium items-center">{{ "Commutes"|trans }}</div>
                                    <ul class="text-sm text-gray-700">
                                        <li>
                                            <div>
                                                <input type="radio" id="true" data-dataTable-filter="isCommute" name="isCommute" value="true" class="peer" />
                                                <label for="true">
                                                    {{ "Commutes only"|trans }}
                                                </label>
                                                <a href="#" data-datatable-filter-clear="isCommute">{{ "clear"|trans }}</a>
                                            </div>
                                        </li>
                                        <li>
                                            <div>
                                                <input type="radio" id="false" data-dataTable-filter="isCommute" name="isCommute" value="false" class="peer" />
                                                <label for="false">
                                                    {{ "Excludes commutes"|trans }}
                                                </label>
                                                <a href="#" data-datatable-filter-clear="isCommute">{{ "clear"|trans }}</a>
                                            </div>
                                        </li>
                                    </ul>
                                </div>
                                <div class="flex flex-col items-center">
                                    <div class="text-xs font-medium">{{ "Workout type"|trans }}</div>
                                    <ul class="text-sm text-gray-700">
                                        {% for workoutType in enum('App\\Domain\\Activity\\WorkoutType').cases() %}
                                            <li>
                                                <div>
                                                    <input type="radio" id="{{ workoutType.value }}" data-dataTable-filter="workoutType" name="workoutType" value="{{ workoutType.value }}" class="peer" />
                                                    <label for="{{ workoutType.value }}">
                                                        {{ workoutType|trans }}
                                                    </label>
                                                    <a href="#" data-datatable-filter-clear="workoutType">{{ "clear"|trans }}</a>
                                                </div>
                                            </li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
            <div class="flex items-center justify-between gap-x-2 text-xs text-gray-700">
                <div>
                    {% set numberOfResults = '<span class="font-bold" data-dataTable-result-count>' ~ numberOfRoutes ~ '</span>' %}
                    {{ "{numberOfResults} routes"|trans({'{numberOfResults}': numberOfResults}) }}
                </div>
                <a href="#" class="hidden font-medium text-primary hover:underline" data-dataTable-reset>{{ "Clear all filters"|trans }}</a>
            </div>
        </div>
        <!-- HEATMAP -->
        <div id="heatmap" data-heatmap-config='{{ heatmapConfig|json_encode}}' data-leaflet-routes='{{ relativeUrl('api/heatmap/routes.json') }}'
             class="grid grid-cols-1 h-[calc(100vh-235px)] rounded-lg {{ heatmapConfig.getLeafletConfig().enableGreyScale() ? 'enable-grey-scale' : '' }}">
        </div>
        <div class="hidden lg:block z-10000 absolute bottom-3 left-3 py-2 px-4 bg-white border border-gray-200 rounded-lg shadow-xs text-xs">
            {% set percentage = (numberOfCountriesWithWorkouts / 195 * 100)|formatNumber(0) %}
            <div class="font-semibold text-gray-700 text-sm mb-0.5">{{ numberOfCountriesWithWorkouts }} {{ "countries"|trans }}</div>
            <div class="text-gray-500"> {{ "That's {percentage}% of all countries 🌍"|trans({'{percentage}': percentage}) }}</div>
        </div>
    </div>
{% endautoescape %}