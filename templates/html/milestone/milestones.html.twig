{% macro milestoneDescription(milestone) %}
    {% set context = milestone.getContext() %}
    {% set category = milestone.getCategory().value %}

    {% if category == 'first' %}
        {{ "First {sportType} activity: {activityName}"|trans({
            '{sportType}': context.getSportType()|trans,
            '{activityName}': context.getActivityName()
        }) }}
    {% elseif category == 'cumulativeDistance' %}
        {{ "Reached {threshold} total distance (actual: {totalDistance})"|trans({
            '{threshold}': context.getThreshold(),
            '{totalDistance}': context.getTotalDistance()
        }) }}
    {% elseif category == 'activityDistance' %}
        {{ "Longest distance"|trans }}: {{ context.getValue()|renderMeasurement(1)|raw }}
    {% elseif category == 'cumulativeElevation' %}
        {{ "Reached {threshold} total elevation (actual: {totalElevation})"|trans({
            '{threshold}': context.getThreshold(),
            '{totalElevation}': context.getTotalElevation()
        }) }}
    {% elseif category == 'activityElevation' %}
        {{ "Most elevation"|trans }}: {{ context.getValue()|renderMeasurement(0)|raw }}
    {% elseif category == 'cumulativeMovingTime' %}
        {{ "Reached {threshold} total moving time (actual: {totalMovingTime})"|trans({
            '{threshold}': context.getThreshold(),
            '{totalMovingTime}': context.getTotalMovingTime()
        }) }}
    {% elseif category == 'activityMovingTime' %}
        {{ "Longest activity"|trans }}: {{ context.getValue()|formatSeconds }}
    {% elseif category == 'activityCount' %}
        {{ "Completed activity number {threshold} (total: {totalCount})"|trans({
            '{threshold}': context.getThreshold(),
            '{totalCount}': context.getTotalCount()
        }) }}
    {% elseif category == 'personalBest' %}
        {{ "New personal best for"|trans }} {{ context.getDistance()|renderMeasurement(1)|raw }}: {{ context.getTime()|formatSeconds }}
    {% elseif category == 'eddington' %}
        {{ "Reached Eddington number {number}"|trans({'{number}': context.getNumber()}) }}
    {% elseif category == 'streak' %}
        {{ "{days} consecutive days of activity"|trans({'{days}': context.getDays()}) }}
    {% endif %}
{% endmacro %}

{% include 'html/navigation/breadcrumbs.html.twig' with {'breadcrumbs': [{
    'url': 'milestones',
    'label': 'Milestones'|trans
}]} %}

{% if milestones.isEmpty() %}
    <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs text-center text-gray-500">
        {{ "No milestones achieved yet"|trans }}
    </div>
{% else %}
    {% if milestones.getUniqueFilterGroups()|length > 1 %}
        <div class="flex flex-wrap gap-2 mb-6" data-milestone-filters>
            <button data-milestone-filter="" class="px-3 py-1 text-sm rounded-full bg-blue-600 text-white">
                {{ "All"|trans }}
            </button>
            {% for group in milestones.getUniqueFilterGroups() %}
                <button data-milestone-filter="{{ group.value }}" class="px-3 py-1 text-sm rounded-full bg-gray-100 text-gray-700 hover:bg-gray-200">
                    {{ group|trans }}
                </button>
            {% endfor %}
        </div>
    {% endif %}
    <div class="relative border-l-2 border-gray-200 ml-6">
        {% for milestone in milestones %}
            <div class="mb-8 ml-10" id="{{ milestone.getId() }}" data-milestone-category="{{ milestone.getCategory().getFilterGroup().value }}">
                <div class="absolute -inset-s-10">
                    <div class="flex flex-col items-center gap-y-1 w-20">
                        <div class="flex items-center justify-center size-8 bg-white rounded-full ring-8 ring-gray-50 border border-gray-200">
                            <svg class="size-4 text-strava-orange" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 10h16m-8-3V4M7 7V4m10 3V4M5 20h14a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1H5a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1Zm3-7h.01v.01H8V13Zm4 0h.01v.01H12V13Zm4 0h.01v.01H16V13Zm-8 4h.01v.01H8V17Zm4 0h.01v.01H12V17Zm4 0h.01v.01H16V17Z"></path></svg>
                        </div>
                        <time class="text-xs text-gray-400 bg-gray-50 pb-1.25">{{ milestone.getAchievedOn()|formatDate('normal') }}</time>
                    </div>
                </div>
                <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs">
                    <h3 class="text-sm font-semibold mb-1">{{ milestone.getTitle() }}</h3>
                    <div class="text-sm text-gray-600">
                        {{ _self.milestoneDescription(milestone) }}
                    </div>
                    {% if milestone.getFunComparison() %}
                        <div class="mt-1 text-sm italic text-gray-500">
                            {{ milestone.getFunComparison()|trans }}
                        </div>
                    {% endif %}
                    {% if milestone.getPrevious() %}
                        <div class="mt-1 text-xs text-gray-400">
                            {{ "Previous"|trans }}:
                            <a href="javascript:void(0)" data-scroll-to="{{ milestone.getPrevious().getMilestoneId() }}" class="underline hover:text-gray-600">
                                {{ milestone.getPrevious().getLabel() }}
                            </a>
                            {{ "on"|trans }} {{ milestone.getPrevious().getAchievedOn()|formatDate('normal') }}
                        </div>
                    {% endif %}
                    {% if milestone.getActivityId() %}
                        {% set activity = enrichedActivities.find(milestone.getActivityId()) %}
                        <div class="mt-1 text-sm">{{ activity|activityLink }}</div>
                    {% endif %}
                    {% if milestone.getSportType() %}
                        <span class="mt-2 inline-block text-xs text-gray-400">{{ milestone.getSportType()|trans }}</span>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
