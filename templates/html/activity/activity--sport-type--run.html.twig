{% extends "html/activity/activity--sport-type--generic.html.twig" %}

{% block mainStatsOnTop %}
    {% autoescape false %}
        <section>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                <div class="bg-white rounded-lg p-3 border border-gray-200 shadow-xs">
                    <div class="flex items-center justify-between mb-1">
                        <span class="text-xxs uppercase tracking-wider font-semibold text-gray-500">{{ "Distance"|trans }}</span>
                        <div class="size-6 rounded-md bg-strava-orange/10 text-strava-orange flex items-center justify-center">
                            {{ svg('distance', 'size-3.5') }}
                        </div>
                    </div>
                    <div class="flex items-baseline gap-1">
                        <span class="text-2xl font-black tracking-tight text-gray-900">{{ activity.getDistance().toFloat()|formatNumber(activity.getSportType().getActivityType().getDistancePrecision()) }}</span>
                        <span class="text-xs font-medium text-gray-500">{{ renderUnitSymbol('distance') }}</span>
                    </div>
                </div>
                <div class="bg-white rounded-lg p-3 border border-gray-200 shadow-xs">
                    <div class="flex items-center justify-between mb-1">
                        <span class="text-xxs uppercase tracking-wider font-semibold text-gray-500">{{ "Moving time"|trans }}</span>
                        <div class="size-6 rounded-md bg-strava-orange/10 text-strava-orange flex items-center justify-center">
                            {{ svg('time', 'size-3.5') }}
                        </div>
                    </div>
                    <div class="flex items-baseline gap-1">
                        <span class="text-2xl font-black tracking-tight text-gray-900">{{ activity.getMovingTimeFormatted() }}</span>
                    </div>
                </div>
                <div class="bg-white rounded-lg p-3 border border-gray-200 shadow-xs">
                    <div class="flex items-center justify-between mb-1">
                        <span class="text-xxs uppercase tracking-wider font-semibold text-gray-500">{{ "Avg speed"|trans }}</span>
                        <div class="size-6 rounded-md bg-strava-orange/10 text-strava-orange flex items-center justify-center">
                            {{ svg('speed', 'size-3.5') }}
                        </div>
                    </div>
                    <div class="flex items-baseline gap-1">
                        {% set averageSpeed = activity.getAverageSpeed() %}
                        {% if averageSpeed %}
                            <span class="text-2xl font-black tracking-tight text-gray-900">{{ averageSpeed.toFloat()|formatNumber(1) }}</span>
                            <span class="text-xs font-medium text-gray-500">{{ renderUnitSymbol('speed') }}</span>
                        {% else %}
                            <span class="text-2xl font-black tracking-tight text-gray-900">{{ "n/a"|trans }}</span>
                        {% endif %}
                    </div>
                </div>
                <div class="bg-white rounded-lg p-3 border border-gray-200 shadow-xs">
                    <div class="flex items-center justify-between mb-1">
                        <span class="text-xxs uppercase tracking-wider font-semibold text-gray-500">{{ "Elevation"|trans }}</span>
                        <div class="size-6 rounded-md bg-strava-orange/10 text-strava-orange flex items-center justify-center">
                            {{ svg('elevation', 'size-3.5') }}
                        </div>
                    </div>
                    <div class="flex items-baseline gap-1">
                        <span class="text-2xl font-black tracking-tight text-gray-900">{{ activity.getElevation().toFloat()|formatNumber(0) }}</span>
                        <span class="text-xs font-medium text-gray-500">{{ activity.getElevation().getSymbol() }}</span>
                    </div>
                </div>
            </div>
            <div class="mt-3 grid grid-cols-[repeat(auto-fit,minmax(170px,1fr))] gap-3">
                <div class="bg-gray-50 rounded-lg p-3 flex gap-x-2 items-center justify-between">
                    <span class="text-xs text-gray-500">{{ "Calories"|trans }}</span>
                    <span class="text-sm font-bold text-gray-900">{{ activity.getCalories() }} <span class="text-xxs font-medium text-gray-400">kcal</span></span>
                </div>
                {% if activity.getKilojoules() %}
                    <div class="bg-gray-50 rounded-lg p-3 flex gap-x-2 items-center justify-between">
                        <span class="text-xs text-gray-500">{{ "Energy"|trans }}</span>
                        <span class="text-sm font-bold text-gray-900">{{ activity.getKilojoules() }} <span class="text-xxs font-medium text-gray-400">kJ</span></span>
                    </div>
                {% endif %}
                <div class="bg-gray-50 rounded-lg p-3 flex gap-x-2 items-center justify-between" title="Max 112 rpm">
                    <span class="text-xs text-gray-500">{{ "Cadence"|trans }}</span>
                    <span class="text-sm font-bold text-gray-900">85 <span class="text-xxs font-medium text-gray-400">rpm</span></span>
                </div>
                <a href="#" class="bg-gray-50 rounded-lg p-3 gap-x-2 flex items-center justify-between group" data-router-force-reload data-router-navigate="{{ relativeUrl('activities') }}" data-filters='{{ dataFilters('activities', {gear: activity.getGearIdIncludingNone()}) }}'>
                    <span class="text-xs text-gray-500 shrink-0">{{ "Gear"|trans }}</span>
                    <span class="text-xs font-bold text-gray-900 group-hover:text-strava-orange truncate" title="{{ activity.getGearName() }}">
                            {{ activity.getGearName() ?: 'Unspecified'|trans }}
                        </span>
                </a>
                <a href="#" class="bg-gray-50 rounded-lg p-3 gap-x-2 flex items-center justify-between group" data-router-force-reload data-router-navigate="{{ relativeUrl('activities') }}" data-filters='{{ dataFilters('activities', {device: activity.getDeviceId()}) }}'>
                    <span class="text-xs text-gray-500 shrink-0">{{ "Device"|trans }}</span>
                    <span class="text-xs font-bold text-gray-900 group-hover:text-strava-orange truncate" title="{{ activity.getDeviceName() }}">
                            {{ activity.getDeviceName() ?: 'None'|trans }}
                        </span>
                </a>
            </div>
        </section>
        <div class="flex gap-x-2 overflow-x-auto">
        <div class="w-1/8 min-w-25 flex flex-col items-center justify-center overflow-hidden px-2 py-2 border border-gray-200 rounded-lg shadow-sm">
            <div class="text-center">
                <dd class="text-xs text-gray-500">{{ "Distance"|trans }}</dd>
                <dt class="font-extrabold">{{ activity.getDistance()|renderMeasurement(activity.getSportType().getActivityType().getDistancePrecision()) }}</dt>
            </div>
        </div>
        <div class="w-1/8 min-w-25 flex flex-col items-center justify-center overflow-hidden px-2 py-2 border border-gray-200 rounded-lg shadow-sm">
            <div class="text-center">
                <dd class="text-xs text-gray-500">{{ "Moving time"|trans }}</dd>
                <dt class="font-extrabold">{{ activity.getMovingTimeFormatted() }}</dt>
            </div>
        </div>
        <div class="w-1/8 min-w-25 flex flex-col items-center justify-center overflow-hidden px-2 py-2 border border-gray-200 rounded-lg shadow-sm">
            <div class="text-center">
                <dd class="text-xs text-gray-500">{{ "Pace"|trans }}</dd>
                <dt class="font-extrabold">{{ activity.getPaceInSecPerKm()|formatPace }}</dt>
            </div>
        </div>
        {% set overallGap = splits.getOverallGapPaceInSecondsPerKm() %}
        <div class="w-1/8 min-w-25 flex flex-col items-center justify-center overflow-hidden px-2 py-2 border border-gray-200 rounded-lg shadow-sm">
            <div class="text-center">
                <dd class="text-xs text-gray-500">{{ "GAP"|trans }}</dd>
                {% if overallGap %}
                    <dt class="font-extrabold">{{ overallGap|formatPace }}</dt>
                {% else %}
                    <dt class="font-extrabold">{{ 'n/a'|trans }}</dt>
                {% endif %}
            </div>
        </div>
        <div class="w-1/8 min-w-25 flex flex-col items-center justify-center overflow-hidden px-2 py-2 border border-gray-200 rounded-lg shadow-sm">
            <div class="text-center">
                <dd class="text-xs text-gray-500">{{ "Elevation"|trans }}</dd>
                <dt class="font-extrabold">{{ activity.getElevation()|renderMeasurement(0) }}</dt>
            </div>
        </div>
        <div class="w-1/8 min-w-25 flex flex-col items-center justify-center overflow-hidden px-2 py-2 border border-gray-200 rounded-lg shadow-sm">
            <div class="text-center">
                <dd class="text-xs text-gray-500">{{ "Calories"|trans }}</dd>
                <dt class="font-extrabold">{{ activity.getCalories() }}</dt>
            </div>
        </div>
        <div class="w-1/8 min-w-25 flex flex-col items-center justify-center overflow-hidden px-2 py-4 border border-gray-200 rounded-lg shadow-sm">
            <div class="text-center">
                <dd class="text-xs text-gray-500">{{ "Gear"|trans }}</dd>
                <dt class="text-xs font-extrabold">
                    <a href="#" data-router-navigate="{{ relativeUrl('activities') }}" data-router-force-reload data-filters='{{ dataFilters('activities', {gear: activity.getGearIdIncludingNone()}) }}' class="text-blue-600 hover:underline">
                        {{ activity.getGearName() ?: 'Unspecified'|trans }}
                    </a>
                </dt>
            </div>
        </div>
        <div class="w-1/8 min-w-25 flex flex-col items-center justify-center overflow-hidden px-2 py-4 border border-gray-200 rounded-lg shadow-sm">
            <div class="text-center">
                <dd class="text-xs text-gray-500">{{ "Device"|trans }}</dd>
                <dt class="text-xs font-extrabold">
                    <a href="#" data-router-navigate="{{ relativeUrl('activities') }}" data-router-force-reload data-filters='{{ dataFilters('activities', {device: activity.getDeviceId()}) }}' class="text-blue-600 hover:underline">
                        {{ activity.getDeviceName() ?: 'None'|trans }}
                    </a>
                </dt>
            </div>
        </div>
    </div>
    {% endautoescape %}
{% endblock mainStatsOnTop %}

{% block statsInleftColumn %}
    {% autoescape false %}
    {% if not splits.isEmpty() or not laps.isEmpty() %}
        <div>
            {% if not splits.isEmpty() and not laps.isEmpty() %}
                <div class="tabs tabs--default">
                    <ul id="splitsLapsTab" data-tabs="#splitsLapsTabContent" role="tablist">
                        <li role="presentation">
                            <a href="#" data-tabs-target="#splitsLapsTabSplits" role="tab" aria-controls="chartsTabMetrics">
                                {{ "Splits"|trans }}
                            </a>
                        </li>
                        <li role="presentation">
                            <a href="#" data-tabs-target="#splitsLapsTabLaps" role="tab" aria-controls="chartsTabDistribution">
                                {{ "Laps"|trans }}
                            </a>
                        </li>
                    </ul>
                </div>
            {% endif %}
            <div id="splitsLapsTabContent">
                {% if not splits.isEmpty() %}
                    <div id="splitsLapsTabSplits" role="tabpanel" aria-labelledby="splitsLapsTabSplits-tab">
                        <div class="text-center text-gray-500 text-sm h-[350px] relative overflow-x-auto px-2 pb-2 border border-gray-200 rounded-lg shadow-sm">
                            <div class="bg-white sticky top-0 pt-2 flex items-center text-xs text-gray-700 uppercase font-bold">
                                <div class="w-8 px-2 py-2">{{ renderUnitSymbol('distance') }}</div>
                                <div class="w-20 px-2 py-2">{{ "Pace"|trans }}</div>
                                {% if splits.hasGapPace() %}
                                    <div class="w-20 px-2 py-2">
                                       {{ "GAP"|trans }}
                                    </div>
                                {% endif %}
                                <div class="grow min-w-40 px-2 py-2"></div>
                                <div class="w-20 px-2 py-2">{{ "Elev"|trans }}</div>
                                <div class="w-20 px-2 py-2">{{ "HR"|trans }}</div>
                            </div>
                            {% for split in splits %}
                                <div class="flex items-center border-b last:border-b-0">
                                    <div class="w-8 px-2 py-2 font-bold">
                                        {{ split.getSplitNumber() }}
                                    </div>
                                    <div class="w-20 px-2 py-2">
                                        {{ split.getPaceInSecPerKm()|formatPace }}
                                    </div>
                                    {% if splits.hasGapPace() %}
                                        <div class="w-20 px-2 py-2">
                                            {% set gapPaceInSecondsPerKm = split.getGapPaceInSecondsPerKm() %}
                                            {% if gapPaceInSecondsPerKm %}
                                                {{ gapPaceInSecondsPerKm|formatPace }}
                                            {% else %}
                                                -
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                    <div class="grow min-w-40 px-2 py-2">
                                        <div class=" bg-gray-200 rounded-full h-2.5">
                                            <div class="bg-strava-orange h-2.5 rounded-full" style="width: {{ split.getRelativePacePercentage() }}%"></div>
                                        </div>
                                    </div>
                                    <div class="w-20 px-2 py-2">
                                        {{ split.getElevationDifference()|renderMeasurement(0) }}
                                    </div>
                                    {% if split.getAverageHeartRate() %}
                                        <div class="w-20 px-2 py-2">
                                            {{ split.getAverageHeartRate() }}
                                        </div>
                                    {% else %}
                                        <div class="w-20 px-2 py-2">
                                            {{ "n/a"|trans }}
                                        </div>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
                {% if not laps.isEmpty() %}
                    <div id="splitsLapsTabLaps" role="tabpanel" aria-labelledby="splitsLapsTabLaps-tab">
                        <div class="text-center text-gray-500 text-sm h-[350px] relative overflow-x-auto px-2 pb-2 border border-gray-200 rounded-lg shadow-sm">
                            <div class="bg-white sticky top-0 pt-2 flex items-center text-xs text-gray-700 uppercase font-bold">
                                <div class="w-8 px-2 py-2">{{ "Lap"|trans }}</div>
                                <div class="w-32 px-2 py-2">{{ "Distance"|trans }}</div>
                                <div class="w-32 px-2 py-2">{{ "Time"|trans }}</div>
                                <div class="w-32 px-2 py-2">{{ "Pace"|trans }}</div>
                                <div class="grow min-w-40 px-2 py-2"></div>
                                <div class="w-32 px-2 py-2">{{ "Elev"|trans }}</div>
                                <div class="w-32 px-2 py-2">{{ "HR"|trans }}</div>
                            </div>
                            {% for lap in laps %}
                                <div class="flex items-center border-b last:border-b-0">
                                    <div class="w-8 px-2 py-2 font-bold">
                                        {{ lap.getLapNumber() }}
                                    </div>
                                    <div class="w-32 px-2 py-2">
                                        {{ lap.getDistanceInKilometer()|renderMeasurement(1) }}
                                    </div>
                                    <div class="w-32 px-2 py-2">
                                        {{ lap.getMovingTimeFormatted() }}
                                    </div>
                                    <div class="w-32 px-2 py-2">
                                        {{ lap.getPaceInSecPerKm()|formatPace }}
                                    </div>
                                    <div class="grow min-w-40 px-2 py-2">
                                        <div class=" bg-gray-200 rounded-full h-2.5">
                                            <div class="bg-strava-orange h-2.5 rounded-full" style="width: {{ lap.getRelativePacePercentage() }}%"></div>
                                        </div>
                                    </div>
                                    <div class="w-32 px-2 py-2">
                                        {{ lap.getElevationDifference()|renderMeasurement(0) }}
                                    </div>
                                    {% if lap.getAverageHeartRate() %}
                                        <div class="w-32 px-2 py-2">
                                            {{ lap.getAverageHeartRate() }}
                                        </div>
                                    {% else %}
                                        <div class="w-32 px-2 py-2">
                                            {{ "n/a"|trans }}
                                        </div>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    {% endif %}
    {% endautoescape %}
{% endblock statsInleftColumn %}

{% block extraStatsUnderColumns %}
    {% autoescape false %}
    {% if bestEfforts|length > 0 %}
        <div>
            <div class="font-medium text-gray-900">{{ "Fastest times"|trans }}</div>
            <div class="mb-2 text-gray-500 text-xs">
                {{ "Congrats! You achieved personal bests during this activity."|trans }}
            </div>
            <div class="relative overflow-x-auto px-2 py-2 border border-gray-200 rounded-lg shadow-sm">
                <table class="w-full text-sm text-center text-gray-500">
                    <thead class="text-xs text-gray-700 uppercase">
                    <tr>
                        <th scope="col" class="px-2 py-2">
                            {{ "Distance"|trans }}
                        </th>
                        <th scope="col" class="px-2 py-3">
                            {{ "Time"|trans }}
                        </th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for bestEffort in bestEfforts %}
                        {% set distance = bestEffort.getBestEffortDistance() %}
                        <tr class="border-b last:border-b-0">
                            <th class="px-2 py-2">
                                {{ distance.isLowerThanOne() ? distance.toFloat()|round(1) : distance.toInt() }} {{ distance.getSymbol() }}
                            </th>
                            <td class="px-2 py-2">
                                {{ bestEffort.getFormattedTime() }}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}
    {% endautoescape %}
{% endblock extraStatsUnderColumns %}
