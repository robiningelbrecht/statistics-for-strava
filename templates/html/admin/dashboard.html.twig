{% extends "html/admin/page.html.twig" %}
{% block body %}
    <!-- NAVIGATION -->
    {% autoescape false %}
        {% include 'html/navigation/top-nav-bar.html.twig' with {
            'inAppContext': true
        } %}
    {% endautoescape %}
    <!-- SIDEBAR -->
    <aside class="-translate-x-full md:translate-x-0" aria-label="Sidenav" id="drawer-navigation">
        <div>
            <ul class="space-y-1 pb-2">
                <li>
                    <a title="{{ "Dashboard"|trans }}" href="{{ relativeUrl('admin') }}">
                        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.143 4H4.857A.857.857 0 0 0 4 4.857v4.286c0 .473.384.857.857.857h4.286A.857.857 0 0 0 10 9.143V4.857A.857.857 0 0 0 9.143 4Zm10 0h-4.286a.857.857 0 0 0-.857.857v4.286c0 .473.384.857.857.857h4.286A.857.857 0 0 0 20 9.143V4.857A.857.857 0 0 0 19.143 4Zm-10 10H4.857a.857.857 0 0 0-.857.857v4.286c0 .473.384.857.857.857h4.286a.857.857 0 0 0 .857-.857v-4.286A.857.857 0 0 0 9.143 14Zm10 0h-4.286a.857.857 0 0 0-.857.857v4.286c0 .473.384.857.857.857h4.286a.857.857 0 0 0 .857-.857v-4.286a.857.857 0 0 0-.857-.857Z"/>
                        </svg>
                        <span>{{ "Dashboard"|trans }}</span>
                    </a>
                </li>
                <li>
                    <form method="post" action="{{ relativeUrl(path('admin_logout')) }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                        <button title="{{ "Sign out"|trans }}" class="text-left w-full">
                            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12H4m12 0-4 4m4-4-4-4m3-4h2a3 3 0 0 1 3 3v10a3 3 0 0 1-3 3h-2"/>
                            </svg>
                            <span>{{ "Sign out"|trans }}</span>
                        </button>
                    </form>
                </li>
            </ul>
        </div>
    </aside>
    <section class="flex min-h-screen flex-col justify-center px-6 py-12 sm:px-12">
        <div class="mx-auto w-full max-w-xl">
            <h2 class="mt-4 text-2xl font-bold tracking-tight">Admin area</h2>
            <p class="mt-1 text-sm text-gray-500">
                Signed in as <strong>{{ app.user.userIdentifier }}</strong>.
            </p>
        </div>
    </section>
{% endblock %}
