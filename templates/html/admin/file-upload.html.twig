{% extends "html/admin/page.html.twig" %}
{% block main %}
    {% autoescape false %}
    {% set uploadDisabled = not importMode.isFiles() %}
    <div class="flex flex-col max-h-[calc(100vh-96px)] p-4 bg-white border border-gray-200 rounded-lg shadow-xs">
        <h3 class="shrink-0 text-lg font-semibold">
            {{ "Upload activity files"|trans }}
        </h3>
        {% set codeOpen = '<code class="font-mono text-[0.85em] bg-gray-100 text-gray-800 px-1.5 py-0.5 rounded">' %}
        {% set codeClose = '</code>' %}
        <p class="shrink-0 mt-1 text-sm text-gray-500">
            {{ "Add {fit}, {tcx} or {gpx} files. They are imported every few minutes."|trans({
                '{fit}': codeOpen ~ '.fit' ~ codeClose,
                '{tcx}': codeOpen ~ '.tcx' ~ codeClose,
                '{gpx}': codeOpen ~ '.gpx' ~ codeClose
            }) }}
        </p>
        {% if uploadDisabled %}
            <div class="shrink-0 flex items-center p-4 mt-4 text-sm text-blue-800 border border-blue-300 rounded-lg bg-blue-50" role="alert">
                <svg class="shrink-0 inline size-4 me-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
                </svg>
                <span class="sr-only">Info</span>
                <div>
                    <span class="font-medium">{{ "File upload is only available in file import mode"|trans }}.</span>
                    {{ "You're currently importing from the Strava API. Set {importMode} and rebuild to upload activity files directly, without depending on Strava's API"|trans({'{importMode}': codeOpen ~ 'IMPORT_MODE=files' ~ codeClose}) }}.
                    {{ "Detailed instructions are available in the documentation on"|trans }} <a href="https://docs.getsfs.app/#/getting-started/installation?id=env" class="font-semibold underline hover:no-underline">{{ "the docs"|trans }}</a>.
                </div>
            </div>
        {% endif %}
        <form id="upload-form" {{ uploadDisabled ? 'inert' : '' }} class="flex flex-col min-h-0 mt-8 {{ uploadDisabled ? 'opacity-60 blur-[1px] pointer-events-none select-none' : '' }}" data-supported-file-extensions='{{ supportedFileExtensions }}' data-translations='{{ {
            "filesReadyToUpload": "{count} files ready to upload"|trans,
            "unsupportedFileType": "Unsupported file type"|trans,
        }|json_encode }}' novalidate>
            <label id="dropzone" class="group shrink-0 relative flex flex-col items-center text-center gap-1.5 px-6 py-10 border-2 border-dashed border-gray-300 rounded-xl bg-gray-50 cursor-pointer transition-colors hover:border-primary hover:bg-primary-soft [&.is-dragging]:border-primary [&.is-dragging]:bg-primary-soft [&.is-dragging]:ring-4 [&.is-dragging]:ring-primary/10" for="file-input">
                <input id="file-input" class="sr-only" type="file" multiple accept=".fit,.tcx,.gpx"/>
                <span class="grid place-items-center w-12 h-12 mb-1 rounded-full bg-primary-soft text-primary transition-colors group-hover:bg-primary group-hover:text-white in-[.is-dragging]:bg-primary in-[.is-dragging]:text-white" aria-hidden="true">
                       <svg class="size-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v9m-5 0H5a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-4a1 1 0 0 0-1-1h-2M8 9l4-5 4 5m1 8h.01"/>
                        </svg>
                    </span>
                <span class="text-gray-500 text-sm">
                    {% set strongOpen = '<strong class="font-semibold text-gray-700">' %}
                    {% set strongClose = '</strong>' %}
                    {{ "{strongOpen}Drag & drop{strongClose} or {strongOpen}browse{strongClose} to choose files"|trans({
                        '{strongOpen}': strongOpen,
                        '{strongClose}': strongClose
                    }) }}
                </span>
                <span class="mt-0.5 text-xs text-gray-400">
                    {{ "Supported types"|trans }}:
                    <code class="font-mono text-[0.85em] bg-gray-100 text-gray-800 px-1.5 py-0.5 rounded">.fit</code>
                    <code class="font-mono text-[0.85em] bg-gray-100 text-gray-800 px-1.5 py-0.5 rounded">.tcx</code>
                    <code class="font-mono text-[0.85em] bg-gray-100 text-gray-800 px-1.5 py-0.5 rounded">.gpx</code>
                </span>
            </label>
            <div id="file-list-header" class="shrink-0 flex items-center justify-between gap-2 mt-4 text-xs font-medium text-gray-500" hidden>
                <span id="file-count"></span>
            </div>
            <ul id="file-list" class="list-none mt-2 mb-0 p-0 flex flex-col gap-2 min-h-0 overflow-y-auto overscroll-contain" hidden></ul>
            <div class="shrink-0 flex flex-col gap-2 mt-5 sm:flex-row sm:items-center">
                <button type="submit" id="upload-btn" class="group btn--primary" data-has-loading-state disabled>
                    <span class="label">{{ "Upload files"|trans }}</span>
                    <span class="label--loading">{{ "Uploading..."|trans }}</span>
                </button>
                <button type="button" id="clear-btn" class="hidden btn--secondary">{{ "Clear"|trans }}</button>
            </div>
        </form>
        {% if not uploadDisabled %}
            <div class="shrink-0 mt-6 text-xs text-gray-500">
                {{ "You can also copy files straight into the {watchFolder} folder."|trans({'{watchFolder}': codeOpen ~ 'watch' ~ codeClose}) }}
            </div>
        {% endif %}
    </div>
    {% endautoescape %}
{% endblock main %}
