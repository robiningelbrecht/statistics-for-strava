{% extends "html/admin/page/template.html.twig" %}
{% block main %}
    {% autoescape false %}
    <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs">
        {% set codeOpen = '<code class="font-mono text-[0.85em] bg-gray-100 text-gray-800 px-1.5 py-0.5 rounded">' %}
        {% set codeClose = '</code>' %}
        {% embed 'html/admin/gated-panel.html.twig' with { 'locked': not importMode.isFiles() } %}
            {% block lockTitle %}{% autoescape false %}{{ "File upload is only available in file import mode"|trans }}{% endautoescape %}{% endblock %}
            {% block content %}{% autoescape false %}
                <h3 class="text-lg font-semibold">
                    {{ "Upload activity files"|trans }}
                </h3>
                <p class="mt-1 text-sm text-gray-500">
                    {{ "Add {fit}, {tcx} or {gpx} files. They are imported every few minutes."|trans({
                        '{fit}': codeOpen ~ '.fit' ~ codeClose,
                        '{tcx}': codeOpen ~ '.tcx' ~ codeClose,
                        '{gpx}': codeOpen ~ '.gpx' ~ codeClose
                    }) }}
                </p>
                <form id="upload-form" class="flex flex-col mt-8"
                      data-supported-file-extensions='{{ supportedFileExtensions }}' data-translations='{{ {
                    "filesReadyToUpload": "{count} files ready to upload"|trans,
                    "filesUploaded": "{count} files uploaded"|trans,
                    "unsupportedFileType": "Unsupported file type"|trans,
                    "uploading": "Uploading..."|trans,
                    "uploaded": "Uploaded"|trans,
                    "uploadFailed": "Upload failed"|trans,
                }|json_encode }}' novalidate>
                    <label id="dropzone"
                           class="group relative flex flex-col items-center text-center gap-1.5 px-6 py-10 border-2 border-dashed border-gray-300 rounded-xl bg-gray-50 cursor-pointer transition-colors hover:border-primary hover:bg-primary-soft [&.is-dragging]:border-primary [&.is-dragging]:bg-primary-soft [&.is-dragging]:ring-4 [&.is-dragging]:ring-primary/10"
                           for="file-input">
                        <input id="file-input" class="sr-only" type="file" multiple accept=".fit,.tcx,.gpx"/>
                        <span class="grid place-items-center w-12 h-12 mb-1 rounded-full bg-primary-soft text-primary transition-colors group-hover:bg-primary group-hover:text-white in-[.is-dragging]:bg-primary in-[.is-dragging]:text-white"
                              aria-hidden="true">
                               <svg class="size-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24"
                                    height="24" fill="none" viewBox="0 0 24 24">
                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                                          stroke-width="2"
                                          d="M12 5v9m-5 0H5a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-4a1 1 0 0 0-1-1h-2M8 9l4-5 4 5m1 8h.01"/>
                                </svg>
                            </span>
                        <span class="text-gray-500 text-sm">
                            {% set strongOpen = '<strong class="font-semibold text-gray-700">' %}
                            {% set strongClose = '</strong>' %}
                            {{ "{strongOpen}Drag & drop{strongClose} or {strongOpen}browse{strongClose} to choose files"|trans({
                                '{strongOpen}': strongOpen,
                                '{strongClose}': strongClose
                            }) }}
                        </span>
                        <span class="mt-0.5 text-xs text-gray-400">
                            {{ "Supported types"|trans }}:
                            <code class="font-mono text-[0.85em] bg-gray-100 text-gray-800 px-1.5 py-0.5 rounded">.fit</code>
                            <code class="font-mono text-[0.85em] bg-gray-100 text-gray-800 px-1.5 py-0.5 rounded">.tcx</code>
                            <code class="font-mono text-[0.85em] bg-gray-100 text-gray-800 px-1.5 py-0.5 rounded">.gpx</code>
                        </span>
                    </label>
                    <div id="file-list-header"
                         class="flex items-center justify-between gap-2 mt-4 text-xs font-medium text-gray-500" hidden>
                        <span id="file-count"></span>
                    </div>
                    <ul id="file-list"
                        class="list-none mt-2 mb-0 p-0 grid grid-cols-1 gap-2 md:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4 max-h-68 overflow-y-auto overscroll-contain"
                        hidden></ul>
                    <template id="file-item-template">
                        <li class="flex items-center gap-3 px-3 py-2.5 border border-gray-200 rounded-xl bg-white transition-colors [&.is-invalid]:border-red-300 [&.is-invalid]:bg-red-50 [&.is-uploading]:border-primary/40 [&.is-uploading]:bg-primary-soft [&.is-uploaded]:border-green-300 [&.is-uploaded]:bg-green-50">
                            <span class="grid place-items-center size-8 shrink-0 rounded-lg bg-gray-100 text-gray-500 in-[.is-invalid]:bg-red-100 in-[.is-invalid]:text-red-500 in-[.is-uploading]:bg-primary/10 in-[.is-uploading]:text-primary in-[.is-uploaded]:bg-green-100 in-[.is-uploaded]:text-green-600" aria-hidden="true">
                                <svg class="size-[1.1rem] in-[.is-invalid]:hidden in-[.is-uploading]:hidden in-[.is-uploaded]:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path
                                            d="M14 2v6h6"/></svg>
                                <svg class="size-[1.1rem] hidden animate-spin in-[.is-uploading]:block" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                    <path d="M21 12a9 9 0 1 1-6.219-8.56" opacity="0.9"/></svg>
                                <svg class="size-[1.1rem] hidden in-[.is-uploaded]:block" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20 6L9 17l-5-5"/></svg>
                                <svg class="size-[1.1rem] hidden in-[.is-invalid]:block" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
                            </span>
                            <span class="flex flex-col min-w-0 flex-1">
                                <span class="name text-sm font-medium text-gray-800 truncate"></span>
                                <span class="meta text-xs text-gray-500 in-[.is-invalid]:text-red-500 in-[.is-uploading]:text-primary in-[.is-uploaded]:text-green-600"></span>
                            </span>
                            <button type="button" data-remove-file class="grid place-items-center size-9 shrink-0 p-0 rounded-lg border-0 bg-transparent text-gray-400 shadow-none cursor-pointer transition-colors hover:bg-gray-100 hover:text-gray-900" aria-label="{{ "Remove"|trans }}">
                                <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                     stroke-linecap="round">
                                    <path d="M6 6l12 12M18 6L6 18"/>
                                </svg>
                            </button>
                        </li>
                    </template>
                    <div class="flex flex-col gap-2 mt-5 sm:flex-row sm:items-center">
                        <button type="submit" id="upload-btn" class="group btn--primary" data-has-loading-state disabled>
                            <span class="label">{{ "Upload files"|trans }}</span>
                            <span class="label--loading">{{ "Uploading..."|trans }}</span>
                        </button>
                        <button type="button" id="clear-btn" class="hidden btn--secondary">{{ "Clear"|trans }}</button>
                    </div>
                </form>
                <div class="mt-6 text-xs text-gray-500">
                    {{ "You can also copy files straight into the {watchFolder} folder."|trans({'{watchFolder}': codeOpen ~ 'watch' ~ codeClose}) }}
                </div>
            {% endautoescape %}{% endblock %}
        {% endembed %}
    </div>
    {% endautoescape %}
{% endblock main %}
