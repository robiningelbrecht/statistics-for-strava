{% extends "html/admin/page/template.html.twig" %}
{% block main %}
    {% autoescape false %}
    {% include 'html/admin/page/gear/gear-sub-menu.html.twig' with {activeMenuItem: 'gearMaintenanceLogs'} %}
    {% include 'html/admin/page/gear/maintenance/maintenance-sub-nav.html.twig' with {activeSubNav: 'log'} %}
    <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold">
                {{ "Maintenance log"|trans }}
            </h3>
            <a href="{{ relativeUrl(path('admin_register_gear_maintenance_log')) }}" type="button" class="btn--add">
                <svg class="size-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7 7V5"/>
                </svg>
                <span>
                    {{ "Register maintenance"|trans }}
                </span>
            </a>
        </div>
        <div class="relative overflow-x-auto">
            <table class="data-table">
                <thead>
                <tr>
                    <th scope="col" class="text-left">
                        {{ "Performed on"|trans }}
                    </th>
                    <th scope="col" class="text-left">
                        {{ "Component"|trans }}
                    </th>
                    <th scope="col" class="text-left">
                        {{ "Task"|trans }}
                    </th>
                    <th scope="col" class="text-left">
                        {{ "Gear"|trans }}
                    </th>
                    <th scope="col" class="narrow">
                        <span class="sr-only">{{ "Edit"|trans }}</span>
                    </th>
                </tr>
                </thead>
                <tbody>
                {% for item in overview %}
                    <tr class="group/row">
                        <td class="text-left whitespace-nowrap font-medium text-gray-800">
                            {{ item.getPerformedOn()|formatDate('normal') }}
                        </td>
                        <td class="text-left whitespace-nowrap">
                            {{ item.getComponentLabel() }}
                        </td>
                        <td class="text-left whitespace-nowrap">
                            {{ item.getTaskLabel() }}
                        </td>
                        <td class="text-left whitespace-nowrap">
                            <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-600">
                                {{ item.getGearName() }}
                            </span>
                        </td>
                        <td class="narrow whitespace-nowrap">
                            <div class="inline-flex items-center gap-2">
                                <a href="{{ relativeUrl(path('admin_edit_gear_maintenance_log', {gearMaintenanceLogId: item.getGearMaintenanceLogId()})) }}"
                                   class="inline-flex items-center justify-center text-gray-500 transition-colors hover:text-primary"
                                   title="{{ "Edit"|trans }}">
                                    <span class="sr-only">{{ "Edit"|trans }}</span>
                                    <svg class="size-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m14.304 4.844 2.852 2.852M7 7H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h11a1 1 0 0 0 1-1v-4.5m2.409-9.91a2.017 2.017 0 0 1 0 2.853l-6.844 6.844L8 14l.713-3.565 6.844-6.844a2.015 2.015 0 0 1 2.852 0Z"/>
                                    </svg>
                                </a>
                                <a href="{{ relativeUrl(path('admin_delete_gear_maintenance_log', {gearMaintenanceLogId: item.getGearMaintenanceLogId()})) }}"
                                   class="inline-flex items-center justify-center text-gray-500 transition-colors hover:text-red-600"
                                   title="{{ "Delete"|trans }}">
                                    <span class="sr-only">{{ "Delete"|trans }}</span>
                                    <svg class="size-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 7h14m-9 3v8m4-8v8M10 3h4a1 1 0 0 1 1 1v3H9V4a1 1 0 0 1 1-1ZM6 7h12v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V7Z"/>
                                    </svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                {% if overview.isEmpty() %}
                    <tr>
                        <td colspan="5">
                            <div class="flex flex-col items-center justify-center gap-3 py-12 px-4 text-center">
                                <span class="grid place-items-center size-12 rounded-full bg-gray-100 text-gray-400" aria-hidden="true">
                                    <svg class="size-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m10.051 8.102-3.778.322-1.994 1.994a.94.94 0 0 0 .533 1.6l2.698.316m8.39 1.617-.322 3.78-1.994 1.994a.94.94 0 0 1-1.595-.533l-.4-2.652m8.166-11.174a1.366 1.366 0 0 0-1.12-1.12c-1.616-.279-4.906-.623-6.38.853-1.671 1.672-5.211 8.015-6.31 10.023a.932.932 0 0 0 .162 1.111l.828.835.833.832a.932.932 0 0 0 1.111.163c2.008-1.102 8.35-4.642 10.021-6.312 1.475-1.478 1.133-4.77.855-6.385Zm-2.961 3.722a1.88 1.88 0 1 1-3.76 0 1.88 1.88 0 0 1 3.76 0Z"/>
                                    </svg>
                                </span>
                                <div class="flex flex-col gap-1">
                                    <span class="text-sm font-medium text-gray-800">{{ "No maintenance logs yet."|trans }}</span>
                                    <span class="text-xs text-gray-500">{{ "Maintenance logs will appear here once maintenance has been registered."|trans }}</span>
                                </div>
                            </div>
                        </td>
                    </tr>
                {% endif %}
                </tbody>
            </table>
        </div>
        {% include 'html/admin/component/pagination.html.twig' with {
            'total': overview.getTotal(),
            'pagination': overview.getPagination(),
        } only %}
    </div>
    {% endautoescape %}
{% endblock main %}
