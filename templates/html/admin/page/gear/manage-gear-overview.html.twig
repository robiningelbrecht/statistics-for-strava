{% extends "html/admin/page/template.html.twig" %}
{% block main %}
    {% autoescape false %}
    <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold">
                {{ "Gear management"|trans }}
            </h3>
            <a href="{{ relativeUrl(path('admin_add_gear')) }}" type="button" class="btn--add">
                <svg class="size-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7 7V5"/>
                </svg>
                <span>
                    {{ "Add gear"|trans }}
                </span>
            </a>
        </div>
        <div class="relative overflow-x-auto">
            <table class="data-table">
                <thead>
                <tr>
                    <th scope="col" class="text-left">
                        {{ "Name"|trans }}
                    </th>
                    <th scope="col" class="narrow">
                        {{ "Dist."|trans }}
                    </th>
                    <th scope="col">
                        {{ "Purchase price"|trans }}
                    </th>
                    <th scope="col">
                        {{ "Status"|trans }}
                    </th>
                    <th scope="col" class="narrow">
                        <span class="sr-only">{{ "Edit"|trans }}</span>
                    </th>
                </tr>
                </thead>
                <tbody>
                {% for gear in gears %}
                    <tr class="group/row">
                        <td class="narrow whitespace-nowrap text-left">
                           {{ gear.getOriginalName() }}
                        </td>
                        <td class="whitespace-nowrap">
                            {% if gear.getDistance().toFloat() > 0 %}
                                {{ gear.getDistance()|renderMeasurement(0) }}
                            {% else %}
                                0<span class="text-xxs ml-px">{{ gear.getDistance().getSymbol() }}</span>
                            {% endif %}
                        </td>
                        <td class="whitespace-nowrap">
                            {% set purchasePrice = gear.getPurchasePrice() %}
                            {% if purchasePrice %}
                                {{ purchasePrice|formatMoney }}
                            {% else %}
                                -
                            {% endif %}
                        </td>
                        <td class="whitespace-nowrap">
                            {% set isActive = gear.getStatus().isActive() %}
                            <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium {{ isActive ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600' }}">
                                <span class="size-1.5 rounded-full {{ isActive ? 'bg-green-500' : 'bg-gray-400' }}"></span>
                                {{ gear.getStatus()|trans }}
                            </span>
                        </td>
                        <td class="narrow whitespace-nowrap">
                            <a href="{{ relativeUrl('admin/gear/' ~ gear.getId()) ~ '/edit' }}"
                               class="inline-flex items-center justify-center text-gray-500 transition-colors hover:text-primary"
                               title="{{ "Edit"|trans }}">
                                <span class="sr-only">{{ "Edit"|trans }}</span>
                                <svg class="size-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m14.304 4.844 2.852 2.852M7 7H4a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h11a1 1 0 0 0 1-1v-4.5m2.409-9.91a2.017 2.017 0 0 1 0 2.853l-6.844 6.844L8 14l.713-3.565 6.844-6.844a2.015 2.015 0 0 1 2.852 0Z"/>
                                </svg>
                            </a>
                        </td>
                    </tr>
                {% endfor %}
                {% if gears.isEmpty() %}
                    <tr>
                        <td colspan="5">
                            <div class="flex flex-col items-center justify-center gap-3 py-12 px-4 text-center">
                                <span class="grid place-items-center size-12 rounded-full bg-gray-100 text-gray-400" aria-hidden="true">
                                    <svg class="size-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m10.051 8.102-3.778.322-1.994 1.994a.94.94 0 0 0 .533 1.6l2.698.316m8.39 1.617-.322 3.78-1.994 1.994a.94.94 0 0 1-1.595-.533l-.4-2.652m8.166-11.174a1.366 1.366 0 0 0-1.12-1.12c-1.616-.279-4.906-.623-6.38.853-1.671 1.672-5.211 8.015-6.31 10.023a.932.932 0 0 0 .162 1.111l.828.835.833.832a.932.932 0 0 0 1.111.163c2.008-1.102 8.35-4.642 10.021-6.312 1.475-1.478 1.133-4.77.855-6.385Zm-2.961 3.722a1.88 1.88 0 1 1-3.76 0 1.88 1.88 0 0 1 3.76 0Z"/>
                                    </svg>
                                </span>
                                <div class="flex flex-col gap-1">
                                    <span class="text-sm font-medium text-gray-800">{{ "No gears added yet."|trans }}</span>
                                    <span class="text-xs text-gray-500">{{ "Gear will appear here once you add them."|trans }}</span>
                                </div>
                            </div>
                        </td>
                    </tr>
                {% endif %}
                </tbody>
            </table>
        </div>
    </div>
    {% endautoescape %}
{% endblock main %}
