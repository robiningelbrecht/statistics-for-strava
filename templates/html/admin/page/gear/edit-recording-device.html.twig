{% extends "html/admin/page/template.html.twig" %}
{% block main %}
    {% autoescape false %}
    <div class="modal-like-form">
        <div class="w-full max-w-lg overflow-y-auto p-6 bg-white border border-gray-200 rounded-lg shadow-xl">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold">
                    {{ "Edit recording device"|trans }}
                </h3>
                <a href="{{ relativeUrl(path('admin_manage_recording_devices_overview')) }}" aria-label="{{ "Close"|trans }}"
                   class="grid place-items-center size-8 rounded-lg text-gray-400 transition-colors hover:bg-gray-100 hover:text-gray-900">
                    <svg class="size-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 17.94 6M18 18 6.06 6"/>
                    </svg>
                </a>
            </div>
            <form data-dispatch-command="{{ dispatchCommand }}" data-redirect="{{ relativeUrl(path('admin_manage_recording_devices_overview')) }}" class="flex flex-col gap-4">
                <input type="hidden" name="name" value="{{ recordingDevice.getName() }}">
                <div data-form-error class="hidden rounded-lg bg-red-50 px-3 py-2 text-sm text-red-700" role="alert"></div>
                <div>
                    <label for="recording-device-name">{{ "Name"|trans }}</label>
                    <input type="text" id="recording-device-name" value="{{ recordingDevice.getName() }}" disabled>
                    <p class="mt-1 text-xs text-gray-500">
                        {{ "The name is derived from the device recorded on your activities and can't be edited."|trans }}
                    </p>
                </div>
                <div>
                    <label for="recording-device-purchase-price">{{ "Purchase price"|trans }}</label>
                    {% set purchasePrice = recordingDevice.getPurchasePrice() %}
                    {% set purchasePriceCurrency = purchasePrice ? purchasePrice.getCurrency().getCode() : 'EUR' %}
                    <div class="mt-1 flex gap-2">
                        <input type="number" step="0.01" min="0" id="recording-device-purchase-price" name="purchasePriceAmount" value="{{ purchasePrice|formatMoneyDecimal }}" placeholder="0.00">
                        <select name="purchasePriceCurrency" class="w-auto">
                            {% for currency in currencies() %}
                                <option value="{{ currency }}" {{ currency == purchasePriceCurrency ? 'selected' }}>{{ currency }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div class="flex justify-end gap-2 border-t border-gray-200 pt-4">
                    <a href="{{ relativeUrl(path('admin_manage_recording_devices_overview')) }}" type="button" class="btn--secondary">{{ "Cancel"|trans }}</a>
                    <button type="submit" data-has-loading-state class="group btn--primary">
                        <span class="label">{{ "Save"|trans }}</span>
                        <span class="label--loading">{{ "Saving..."|trans }}</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
    {% endautoescape %}
{% endblock main %}
