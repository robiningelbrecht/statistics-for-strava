{% extends "html/admin/page/template.html.twig" %}
{% block main %}
    {% autoescape false %}
        <form class="p-4 sm:p-6 bg-white border border-gray-200 rounded-lg shadow-xs max-w-6xl">
            <div class="flex flex-wrap items-start justify-between gap-3 mb-1">
                <div>
                    <h3 class="text-lg font-semibold">{{ "Dashboard layout"|trans }}</h3>
                    <p class="mt-1 text-sm text-gray-500 max-w-2xl">
                        {{ "Reorder widgets and set each widget's width."|trans }}
                    </p>
                </div>
                <button type="button" class="btn--add">
                    <svg class="size-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7 7V5"/>
                    </svg>
                    <span>{{ "Add widget"|trans }}</span>
                </button>
            </div>

            <div class="grid grid-cols-12 gap-3 mt-4">
                {% for widget in widgets %}
                    <div class="flex flex-col rounded-lg border border-gray-200 bg-white shadow-xs" data-widget-id="{{ widget.getId() }}" style="grid-column: span {{ widget.getSpan() }} / span {{ widget.getSpan() }};">
                        <div class="flex items-center gap-2 px-3 py-2 border-b border-gray-100">
                            <span class="shrink-0 text-gray-400" title="{{ "Drag to reorder"|trans }}">
                                <svg class="size-4.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 6h.01M9 12h.01M9 18h.01M15 6h.01M15 12h.01M15 18h.01"/>
                                </svg>
                            </span>
                            <span class="min-w-0 truncate text-sm font-medium text-gray-800">{{ widget.getLabel() }}</span>
                            <div class="ml-auto flex items-center gap-1.5 shrink-0">
                                {% if widget.isConfigurable() %}
                                    <button type="button" class="unstyled text-gray-400 hover:text-primary p-1 rounded-md hover:bg-gray-100" title="{{ "Configure"|trans }}">
                                        <svg class="size-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13v-2a1 1 0 0 0-1-1h-.757l-.707-1.707.535-.536a1 1 0 0 0 0-1.414l-1.414-1.414a1 1 0 0 0-1.414 0l-.536.535L14 4.757V4a1 1 0 0 0-1-1h-2a1 1 0 0 0-1 1v.757l-1.707.707-.536-.535a1 1 0 0 0-1.414 0L4.929 6.343a1 1 0 0 0 0 1.414l.536.536L4.757 10H4a1 1 0 0 0-1 1v2a1 1 0 0 0 1 1h.757l.707 1.707-.535.536a1 1 0 0 0 0 1.414l1.414 1.414a1 1 0 0 0 1.414 0l.536-.535 1.707.707V20a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1v-.757l1.707-.708.536.536a1 1 0 0 0 1.414 0l1.414-1.414a1 1 0 0 0 0-1.414l-.535-.536.707-1.707H20a1 1 0 0 0 1-1Z"/>
                                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/>
                                        </svg>
                                    </button>
                                {% endif %}
                                <button type="button" class="unstyled text-gray-300 hover:text-red-600 p-1 rounded-md hover:bg-red-50" title="{{ "Remove widget"|trans }}">
                                    <svg class="size-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 17.94 6M18 18 6.06 6"/>
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <div class="flex-1 px-3 py-3">
                            <div class="flex h-full min-h-16 flex-col justify-center gap-2 rounded-md border border-dashed border-gray-200 bg-gray-50/60 px-3 py-3">
                                <div class="h-2 w-1/3 rounded bg-gray-200"></div>
                                <div class="h-2 w-2/3 rounded bg-gray-200"></div>
                                <div class="h-2 w-1/2 rounded bg-gray-200"></div>
                            </div>
                        </div>

                        <div class="flex items-center justify-between gap-2 px-3 py-2 border-t border-gray-100">
                            <div class="inline-flex rounded-md border border-gray-200 bg-gray-50 p-0.5 text-xxs font-medium">
                                {% for width in widths %}
                                    <button type="button" class="unstyled rounded px-1.5 py-0.5 {{ width == widget.getWidth() ? 'bg-white text-primary shadow-xs' : 'text-gray-500 hover:text-gray-800' }}">{{ width }}%</button>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <div class="sticky bottom-0 z-10 -mx-4 sm:-mx-6 -mb-4 sm:-mb-6 mt-6 flex items-center justify-between gap-2 rounded-b-lg border-t border-gray-200 bg-white px-4 sm:px-6 py-4">
                <button type="submit" class="btn--secondary">{{ "Reset to default"|trans }}</button>
                <button type="submit" class="btn--primary">{{ "Save layout"|trans }}</button>
            </div>
        </form>
    {% endautoescape %}
{% endblock main %}
