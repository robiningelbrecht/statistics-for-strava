{% autoescape false %}
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <title>{{ appName }}</title>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width">
        <meta name="theme-color" content="#F26822">
        <meta name="mobile-web-app-title" content="{{ appName }}">
        <meta name="mobile-web-app-capable" content="yes">
        <link rel="icon" type="image/x-icon" href="{{ relativeUrl('assets/images/logo.svg') }}">
        <link href="{{ relativeUrl(asset('css/dist/tailwind.min.css')) }}" rel="stylesheet"/>
        <script>
            document.documentElement.setAttribute('data-theme', localStorage.getItem('theme') || 'light');
        </script>
    </head>
    <body class="min-h-screen bg-gray-50 text-gray-900 antialiased admin">
    <section class="flex min-h-screen flex-col justify-center px-6 py-12 sm:px-12">
        <div class="mx-auto w-full max-w-sm">
            <img class="mx-auto h-12 w-auto" src="{{ relativeUrl('assets/images/logo.svg') }}" alt="{{ appName }}">
            <h1 class="mt-6 text-center text-2xl font-bold tracking-tight">{{ appName }}</h1>
            <p class="mt-1 text-center text-sm text-gray-500">{{ "Sign in to the admin area"|trans }}</p>
            {% if error %}
                <div class="mt-6 overflow-hidden rounded-xl border border-red-200 bg-red-100/60 text-red-700">
                    <p class="px-4 py-3 text-sm">{{ error.messageKey|trans(error.messageData, 'security') }}</p>
                </div>
            {% endif %}
            <form class="mt-6 space-y-4" method="post" action="{{ relativeUrl(path('admin_login')) }}">
                <div>
                    <label for="username">{{ "Username"|trans }}</label>
                    <div class="mt-1 flex items-center rounded-xl border border-gray-300 shadow-sm overflow-hidden focus-within:border-primary focus-within:ring-1 focus-within:ring-primary">
                    <span class="flex items-center self-stretch px-3 bg-gray-100 text-gray-500 border-r border-gray-300">
                        <svg class="size-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                          <path stroke="currentColor" stroke-width="2" d="M7 17v1a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-1a3 3 0 0 0-3-3h-4a3 3 0 0 0-3 3Zm8-9a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                        </svg>
                    </span>
                        <input type="text" id="username" name="_username" autocomplete="username" required autofocus placeholder="{{ "Enter your username"|trans }}"
                               class="block w-full border-0 px-3 py-2 bg-transparent focus:outline-none focus:ring-0">
                    </div>
                </div>
                <div>
                    <label for="password">{{ "Password"|trans }}</label>
                    <div class="mt-1 flex items-center rounded-xl border border-gray-300 shadow-sm overflow-hidden focus-within:border-primary focus-within:ring-1 focus-within:ring-primary">
                        <span class="flex items-center self-stretch px-3 bg-gray-100 text-gray-500 border-r border-gray-300">
                            <svg class="size-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14v3m-3-6V7a3 3 0 1 1 6 0v4m-8 0h10a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1v-7a1 1 0 0 1 1-1Z"/>
                            </svg>
                        </span>
                        <input type="password" id="password" name="_password" autocomplete="current-password" required placeholder="{{ "Enter your password"|trans }}"
                               class="block w-full border-0 px-3 py-2 bg-transparent focus:outline-none focus:ring-0">
                        <button type="button" data-toggle-password="password" aria-label="{{ "Show password"|trans }}"
                                class="cursor-pointer flex items-center self-stretch px-3 text-gray-500 hover:text-gray-700 focus:outline-none">
                            <svg class="size-4" data-icon-show aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                              <path stroke="currentColor" stroke-width="2" d="M21 12c0 1.2-4.03 6-9 6s-9-4.8-9-6c0-1.2 4.03-6 9-6s9 4.8 9 6Z"/>
                              <path stroke="currentColor" stroke-width="2" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                            </svg>
                            <svg class="size-4 hidden" data-icon-hide aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.933 13.909A4.357 4.357 0 0 1 3 12c0-1 4-6 9-6m7.6 3.8A5.068 5.068 0 0 1 21 12c0 1-3 6-9 6-.314 0-.62-.014-.918-.04M5 19 19 5m-4 7a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                            </svg>
                        </button>
                    </div>
                </div>
                <label class="flex items-center gap-2 text-sm text-gray-700">
                    <input type="checkbox" name="_remember_me">
                    <span>{{ "Remember me for 7 days"|trans }}</span>
                </label>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <button type="submit" data-has-loading-state class="group w-full btn--primary">
                    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 0 1 8-8V0C5.373 0 0 5.373 0 12h4Z"></path>
                    </svg>
                    <span class="label">{{ "Sign in"|trans }}</span>
                    <span class="label--loading">{{ "Signing in..."|trans }}</span>
                </button>
            </form>
            <p class="mt-6 text-center">
                <a href="{{ relativeUrl('/') }}"
                   class="inline-flex items-center gap-x-1.5 text-sm font-medium text-gray-500 hover:text-gray-900">
                    <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
                    {{ "Back to app"|trans }}
                </a>
            </p>
        </div>
    </section>
    <script src="{{ relativeUrl(asset('js/dist/admin.min.js')) }}" type="module"></script>
    </body>
    </html>
{% endautoescape %}
