{% set locked = locked ?? false %}
{% if locked %}
    <div class="relative">
        <div class="opacity-60 blur-[2px] pointer-events-none select-none" inert>
            {% block content %}{% endblock %}
        </div>
        <div class="absolute inset-0 z-10 flex items-center justify-center p-4 rounded-lg bg-white/55" role="alert">
            <div class="w-full max-w-xl p-6 text-center bg-white border border-gray-200 rounded-xl shadow-lg">
                {% block lockIcon %}
                    <span class="grid place-items-center size-12 mx-auto mb-3 rounded-full bg-blue-50 text-blue-600" aria-hidden="true">
                        <svg class="size-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14v3m-3-6V7a3 3 0 1 1 6 0v4m-8 0h10a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1v-7a1 1 0 0 1 1-1Z"/>
                        </svg>
                    </span>
                {% endblock %}
                <h3 class="text-base font-semibold text-gray-900">{% block lockTitle %}{% endblock %}</h3>
                <div class="mt-3 space-y-3">{% autoescape false %}
                    {% set codeOpen = '<code class="font-mono text-[0.85em] bg-gray-100 text-gray-800 px-1.5 py-0.5 rounded">' %}
                    {% set codeClose = '</code>' %}
                    <p class="text-sm text-gray-500">
                        {{ "You're currently importing from the Strava API. Set {importMode} to upload activity files directly, without depending on Strava's API"|trans({'{importMode}': codeOpen ~ 'IMPORT_MODE=files' ~ codeClose}) }}.
                    </p>
                    {% set linkOpen = '<a class="font-semibold underline hover:no-underline" href="https://docs.getsfs.app/#/getting-started/installation?id=env">' %}
                    {% set linkClose = '</a>' %}
                    <p class="text-xs text-gray-400">
                        {{ "Detailed instructions are available in {linkOpen}the documentation{linkClose}."|trans({'{linkOpen}': linkOpen, '{linkClose}': linkClose}) }}
                    </p>
                {% endautoescape %}</div>
            </div>
        </div>
    </div>
{% else %}
    {{ block('content') }}
{% endif %}
