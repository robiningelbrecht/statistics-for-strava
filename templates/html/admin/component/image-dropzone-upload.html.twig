{% autoescape false %}
    {% set extensions = extensions ?? supportedImageExtensions() %}
    {% set maxImages = maxImages ?? 1 %}
    {% set maxFileSize = maxFileSize ?? 5 %}
    {% set maxTotalSize = maxTotalSize ?? 15 %}
    {% set name = name ?? 'images' %}
    {% set existingImages = existingImages ?? [] %}
    {% set id = id ?? ('image-dropzone-' ~ name) %}
    {% set title = title ?? null %}
    {% set description = description ?? null %}
    {% set accept = '.' ~ extensions|join(',.') %}
    {% set strongOpen = '<strong class="font-semibold text-gray-700">' %}
    {% set strongClose = '</strong>' %}

    <div data-image-dropzone
         data-max-images="{{ maxImages }}"
         data-max-file-size="{{ maxFileSize * 1024 * 1024 }}"
         data-max-total-size="{{ maxTotalSize * 1024 * 1024 }}"
         data-supported-extensions='{{ extensions|json_encode }}'
         data-existing-images='{{ existingImages|json_encode }}'
         data-translations='{{ {
             "imagesSelected": "{count} images selected"|trans,
             "unsupportedFileType": "Unsupported file type"|trans,
             "fileTooLarge": "File exceeds {max} MB"|trans,
             "limitReached": "You can select up to {max} images"|trans,
             "totalSizeExceeded": "Total size exceeds {max} MB"|trans,
             "existingImage": "Saved"|trans,
         }|json_encode }}'
         class="flex flex-col">
        <input type="hidden" data-images-field name="{{ name }}"/>
        {% if title %}<h3 class="text-lg font-semibold">{{ title }}</h3>{% endif %}
        {% if description %}<p class="mt-1 text-sm text-gray-500">{{ description }}</p>{% endif %}
        <label data-dropzone
               class="group relative flex flex-col items-center text-center gap-1.5 px-6 py-10 border-2 border-dashed border-gray-300 rounded-xl bg-gray-50 cursor-pointer transition-colors hover:border-primary hover:bg-primary-soft [&.is-dragging]:border-primary [&.is-dragging]:bg-primary-soft [&.is-dragging]:ring-4 [&.is-dragging]:ring-primary/10 [&.is-disabled]:opacity-50 [&.is-disabled]:pointer-events-none"
               for="{{ id }}-input">
            <input id="{{ id }}-input" data-input class="sr-only" type="file" accept="{{ accept }}" multiple/>
            <span class="grid place-items-center w-12 h-12 mb-1 rounded-full bg-primary-soft text-primary transition-colors group-hover:bg-primary group-hover:text-white in-[.is-dragging]:bg-primary in-[.is-dragging]:text-white"
                  aria-hidden="true">
                <svg class="size-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M4 16v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2m-4-7-4-4m0 0L8 9m4-4v11"/>
                </svg>
            </span>
            <span class="text-gray-500 text-sm">
                {{ "{strongOpen}Drag & drop{strongClose} or {strongOpen}browse{strongClose} to choose images"|trans({
                    '{strongOpen}': strongOpen,
                    '{strongClose}': strongClose
                }) }}
            </span>
            <span class="mt-0.5 text-xs text-gray-400">
                {{ "Supported types"|trans }}:
                {% for extension in extensions %}
                    <code class="font-mono text-[0.85em] bg-gray-100 text-gray-800 px-1.5 py-0.5 rounded">.{{ extension }}</code>
                {% endfor %}
                {{ "max {max} MB each"|trans({'{max}': maxFileSize}) }}
            </span>
        </label>
        <div data-list-header class="flex items-center justify-between gap-2 mt-4 text-xs font-medium text-gray-500" hidden>
            <span data-count></span>
        </div>
        <ul data-list
            class="list-none mt-2 mb-0 p-0 flex flex-col gap-2 max-h-68 overflow-y-auto overscroll-contain"
            hidden></ul>
        <template data-item-template>
            <li class="flex items-center gap-3 px-3 py-2.5 border border-gray-200 rounded-xl bg-white transition-colors [&.is-invalid]:border-red-300 [&.is-invalid]:bg-red-50">
                <img data-preview alt="" class="size-10 shrink-0 rounded-lg object-cover bg-gray-100"/>
                <span class="flex flex-col min-w-0 flex-1">
                    <span class="name text-sm font-medium text-gray-800 truncate"></span>
                    <span class="meta text-xs text-gray-500 in-[.is-invalid]:text-red-500"></span>
                </span>
                <button type="button" data-remove-file class="grid place-items-center size-9 shrink-0 p-0 rounded-lg border-0 bg-transparent text-gray-400 shadow-none cursor-pointer transition-colors hover:bg-gray-100 hover:text-gray-900" aria-label="{{ "Remove"|trans }}">
                    <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <path d="M6 6l12 12M18 6L6 18"/>
                    </svg>
                </button>
            </li>
        </template>
        <div class="mt-3">
            <button type="button" data-clear-btn class="hidden btn--secondary">{{ "Clear"|trans }}</button>
        </div>
    </div>
{% endautoescape %}
