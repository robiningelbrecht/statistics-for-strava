{% autoescape false %}
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <title>{{ appName }}</title>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width">
        <meta name="theme-color" content="#F26822">
        <meta name="mobile-web-app-title" content="{{ appName }}">
        <meta name="mobile-web-app-capable" content="yes">
        <link rel="icon" type="image/x-icon" href="{{ relativeUrl('assets/images/logo.svg') }}">
        <link href="{{ relativeUrl(asset('css/dist/tailwind.min.css')) }}" rel="stylesheet"/>
        <script>
            document.documentElement.setAttribute('data-theme', localStorage.getItem('theme') || 'light');
            if (localStorage.getItem('sideNavCollapsed') === 'true') {
                document.documentElement.setAttribute('data-sidebar-collapsed', '');
            }
        </script>
    </head>
    <body class="min-h-screen bg-gray-50 text-gray-900 antialiased admin">
        <!-- NAVIGATION -->
        {% autoescape false %}
            {% include 'html/admin/navigation/top-nav-bar.html.twig' %}
        {% endautoescape %}
        <!-- SIDEBAR -->
        <aside class="-translate-x-full md:translate-x-0" aria-label="Sidenav" id="drawer-navigation">
            <div>
                <ul class="space-y-1 pb-2">
                    <li>
                        <a title="{{ "File upload"|trans }}" href="{{ relativeUrl('admin/upload') }}" {{ isActiveNavItem({'/admin': true, '/admin/upload': false}) ? 'aria-selected="true"' : '' }}>
                            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v9m-5 0H5a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-4a1 1 0 0 0-1-1h-2M8 9l4-5 4 5m1 8h.01"/>
                            </svg>
                            <span>{{ "Upload"|trans }}</span>
                        </a>
                    </li>
                </ul>
                <ul class="space-y-1 py-2">
                    <li>
                        <form method="post" action="{{ relativeUrl(path('admin_logout')) }}">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                            <button title="{{ "Sign out"|trans }}" class="text-left w-full">
                                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12H4m12 0-4 4m4-4-4-4m3-4h2a3 3 0 0 1 3 3v10a3 3 0 0 1-3 3h-2"/>
                                </svg>
                                <span>{{ "Sign out"|trans }}</span>
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </aside>
        <main class="p-4 md:ml-64 sidebar-collapsed:md:ml-16 h-auto min-h-screen pt-20 text-gray-900">
            {% block main %}
            {% endblock main %}
        </main>
        <script src="{{ relativeUrl(asset('js/dist/admin.min.js')) }}" type="module"></script>
    </body>
    </html>
{% endautoescape %}