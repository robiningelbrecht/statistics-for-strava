{% set uniqueId = uniqueNumberForId('peakPowerOutputs') %}
{% autoescape false %}
    <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold">{{ "Peak power outputs"|trans }}</h3>
        <a href="#" data-model-content-url="{{ relativeUrl('power-output.html') }}"
           class="inline-flex items-center p-2 text-sm font-medium rounded-lg text-blue-600 hover:bg-gray-100">
            {{ "View details"|trans }}
        </a>
    </div>
    {% if powerOutputsPerActivityType|length > 1 %}
        <div class="tabs tabs--default">
            <ul id="peakPowerOutputActivityTypeTab{{ uniqueId }}" data-tabs="#peakPowerOutputActivityTypeTabContent{{ uniqueId }}" role="tablist">
                {% for activityType,powerOutputs in powerOutputsPerActivityType %}
                    <li role="presentation">
                        <a href="#" data-tabs-target="#powerOutput{{ activityType }}{{ uniqueId }}" role="tab"
                           aria-controls="powerOutput{{ activityType }}{{ uniqueId }}">
                            {{ enum('App\\Domain\\Activity\\ActivityType').from(activityType)|trans }}
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}
    <div id="peakPowerOutputActivityTypeTabContent{{ uniqueId }}">
        {% for activityType,powerOutputs in powerOutputsPerActivityType %}
            <div id="powerOutput{{ activityType }}{{ uniqueId }}" role="tabpanel" aria-labelledby="powerOutput{{ activityType }}{{ uniqueId }}-tab">
                <div class="relative overflow-x-auto">
                    <table class="data-table">
                        <thead>
                        <tr>
                            <th scope="col" class="sticky left-0 bg-gray-50">
                                {{ "Time"|trans }}
                            </th>
                            <th scope="col" colspan="2">
                                {{ "Power"|trans }}
                            </th>
                            <th scope="col" class="text-left">
                                {{ "Activity"|trans }}
                            </th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for powerOutput in powerOutputs %}
                            {% if powerOutput.getTimeIntervalInSeconds() in timeIntervals %}
                                <tr class="group/row">
                                    <td class="sticky left-0 bg-white font-medium text-gray-900 whitespace-nowrap">
                                        {{ powerOutput.getFormattedTimeInterval() }}
                                    </td>
                                    <td>
                                        {{ powerOutput.getPower() }}<span class="text-xxs ml-px">w</span>
                                    </td>
                                    <td>
                                        {{ powerOutput.getRelativePower() }}<span class="text-xxs ml-px">w/kg</span>
                                    </td>
                                    <td class="text-left truncate">
                                        {{ enrichedActivities.find(powerOutput.getActivityId())|activityLink() }}
                                    </td>
                                </tr>
                            {% endif %}
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endfor %}
    </div>
{% endautoescape %}