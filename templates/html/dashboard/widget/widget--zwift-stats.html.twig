{% autoescape false %}
    <h3 class="mb-4 text-lg font-semibold">
        {{ "Zwift stats"|trans }}
    </h3>
    <div class="relative overflow-x-auto">
        <table class="data-table">
            <thead>
            <tr>
                <th scope="col" class="sticky left-0 bg-gray-50">

                </th>
                <th scope="col">
                    # {{ "workouts"|trans }}
                </th>
                <th scope="col">
                    {{ "Dist."|trans }}
                </th>
                <th scope="col">
                    {{ "Elev."|trans }}
                </th>
                <th scope="col">
                    {{ "Moving time"|trans }}
                </th>
                <th scope="col">
                    {{ "Cal."|trans }}
                </th>
            </tr>
            </thead>
            <tbody>
            {% for statistic in statsPerWorld %}
                <tr class="group/row">
                    <th scope="row"
                        class="sticky left-0 bg-white font-medium text-gray-900 whitespace-nowrap">
                        <div>{{ statistic.zwiftWorld }}</div>
                    </th>
                    <td>
                        {{ statistic.numberOfActivities }}
                    </td>
                    <td class="truncate">
                        {{ statistic.distance|renderMeasurement(0) }}
                    </td>
                    <td class="truncate">
                        {{ statistic.elevation|renderMeasurement(0) }}
                    </td>
                    <td class="truncate" title="{{ statistic.movingTime.toHour().toFloat()|formatNumber(1) }}h">
                        {{ statistic.movingTime|formatSeconds }}
                    </td>
                    <td class="truncate">
                        {{ statistic.calories|formatNumber(0) }}<span class="text-xxs ml-px">kcal</span>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endautoescape %}