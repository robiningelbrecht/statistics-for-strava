{% autoescape false %}
    <h3 class="mb-4 text-lg font-semibold">
        {{ "Zwift stats"|trans }}
    </h3>
    <div class="relative overflow-auto max-h-65">
        <table class="data-table">
            <thead>
            <tr>
                <th scope="col" class="narrow sticky left-0 bg-gray-50">
                    {{ "World"|trans }}
                </th>
                <th scope="col" class="narrow">
                    # {{ "workouts"|trans }}
                </th>
                <th scope="col">
                    {{ "Dist."|trans }}
                </th>
                <th scope="col">
                    {{ "Elev."|trans }}
                </th>
                <th scope="col">
                    {{ "Moving time"|trans }}
                </th>
                <th scope="col">
                    {{ "Cal."|trans }}
                </th>
            </tr>
            </thead>
            <tbody>
            {% for statistic in statsPerWorld %}
                <tr class="group/row">
                    <th scope="row"
                        class="narrow sticky left-0 bg-white font-medium text-gray-900 whitespace-nowrap">
                        <div class="flex items-center gap-x-2">
                            <img class="shrink-0 size-10 object-cover lazy rounded-sm" src="{{ placeholderImage() }}" data-src="{{ relativeUrl('assets/images/maps/thumbs/zwift-' ~ statistic.zwiftWorld|lower|replace({' ': '-'}) ~ '.webp') }}" alt="{{ statistic.zwiftWorld }}">
                            <div>{{ statistic.zwiftWorld }}</div>
                        </div>
                    </th>
                    <td class="narrow">
                        {{ statistic.numberOfActivities }}
                    </td>
                    <td class="truncate">
                        {{ statistic.distance|renderMeasurement(0) }}
                    </td>
                    <td class="truncate">
                        {{ statistic.elevation|renderMeasurement(0) }}
                    </td>
                    <td class="truncate" title="{{ statistic.movingTime.toHour().toFloat()|formatNumber(1) }}h">
                        {{ statistic.movingTime|formatSeconds }}
                    </td>
                    <td class="truncate">
                        {{ statistic.calories|formatNumber(0) }}<span class="text-xxs ml-px">kcal</span>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endautoescape %}