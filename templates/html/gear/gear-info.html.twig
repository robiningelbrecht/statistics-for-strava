{% autoescape false %}
    <!-- Modal header -->
    <div class="modal-header flex items-center justify-between">
        <h3>
            <span>{{ "Gear details"|trans }}</span>
        </h3>
        <div class="flex items-center">
            <button type="button" class="close">
                <svg class="size-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                </svg>
                <span class="sr-only">{{ "Close modal"|trans }}</span>
            </button>
        </div>
    </div>
    <!-- Modal body -->
    <div class="modal-body space-y-4">
        <div class="relative overflow-x-auto">
            <table class="data-table">
                <thead>
                <tr>
                    <th scope="col" class="sticky left-0 bg-gray-50">
                        {{ "Name"|trans }}
                    </th>
                    <th scope="col">
                        {{ "Id"|trans }}
                    </th>
                    <th scope="col">
                        {{ "Dist."|trans }}
                    </th>
                </tr>
                </thead>
                <tbody>
                {% for gear in gears %}
                    <tr class="group/row">
                        <th scope="row" class="sticky bg-white left-0 font-medium text-gray-900 whitespace-nowrap">
                            {{ gear.getName() }}
                        </th>
                        <td class="truncate">
                            {{ gear.getId().toUnprefixedString() }}
                        </td>
                        <td class="truncate">
                            {{ gear.getDistance()|renderMeasurement(0) }}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endautoescape %}