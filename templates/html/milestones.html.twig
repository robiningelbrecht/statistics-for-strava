{% include 'html/navigation/breadcrumbs.html.twig' with {'breadcrumbs': [{
    'url': 'milestones',
    'label': 'Milestones'|trans
}]} %}
{% if milestones.isEmpty() %}
    <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs text-center text-gray-500">
        {{ "No milestones achieved yet"|trans }}
    </div>
{% else %}
    {% if milestones.getUniqueFilterGroups()|length > 1 %}
        <div class="flex flex-wrap gap-2 mb-6" data-milestone-filters>
            <div>
                <input type="radio" id="all" value="all" name="filter-group" class="hidden peer" required="" checked>
                <label for="all" class="inline-flex items-center justify-between gap-x-1 rounded-lg cursor-pointer px-4 py-1 text-sm font-medium shadow-xs text-gray-700 bg-white border border-gray-200 hover:text-strava-orange peer-checked:text-strava-orange">
                    {{ "All"|trans }}
                </label>
            </div>
            {% for group in milestones.getUniqueFilterGroups() %}
                <div>
                    <input type="radio" id="{{ group.value }}" value="{{ group.value }}" name="filter-group" class="hidden peer" required="">
                    <label for="{{ group.value }}" class="flex items-center justify-between gap-x-1 rounded-lg cursor-pointer px-4 py-1 text-sm font-medium shadow-xs text-gray-700 bg-white border border-gray-200 hover:text-strava-orange peer-checked:text-strava-orange">
                        {{ svg(group.getSvgIcon(), 'size-4', '') }}
                        <span>{{ group|trans }}</span>
                    </label>
                </div>
            {% endfor %}
        </div>
    {% endif %}
    <div class="relative border-l-2 border-gray-200 ml-6">
        {% set currentYear = null %}
        {% for milestone in milestones %}
            {% set milestoneYear = milestone.getAchievedOn().getYear() %}
            {% if milestoneYear != currentYear %}
                {% set currentYear = milestoneYear %}
                <div class="relative mb-8 -ml-4" data-milestone-year-separator>
                    <div class="flex items-center gap-x-3">
                        <div class="size-8 rounded-full bg-strava-orange flex items-center justify-center ring-8 ring-gray-50">
                            {{ svg('calendar', 'size-4', 'text-white') }}
                        </div>
                        <span class="text-sm font-bold text-gray-700">{{ currentYear }}</span>
                    </div>
                </div>
            {% endif %}
            <div class="mb-8 ml-10" id="{{ milestone.getId() }}" data-milestone-filter-group="{{ milestone.getCategory().getFilterGroup().value }}">
                <div class="absolute -inset-s-10">
                    <div class="flex flex-col items-center gap-y-1 w-20">
                        <div class="flex items-center justify-center size-8 bg-white rounded-full ring-8 ring-gray-50 border border-gray-200">
                            {{ svg(milestone.getCategory().getFilterGroup().getSvgIcon(), 'size-4', 'text-strava-orange') }}
                        </div>
                        <time class="text-xs text-gray-500 bg-gray-50 pb-1.25">{{ milestone.getAchievedOn()|formatDate('normal') }}</time>
                    </div>
                </div>
                <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs">
                    <div class="flex items-center gap-x-1 mb-1">
                        {% if milestone.getSportType() %}
                            <div class="px-2 py-0.5 text-xxs font-medium border border-gray-200 text-strava-orange bg-white rounded-lg">
                                {{ milestone.getSportType()|trans }}
                            </div>
                        {% endif %}
                        <h3 class="text-base font-bold text-gray-900">{{ _self.milestoneTitle(milestone) }}</h3>
                    </div>
                    <div class="text-sm text-gray-600">
                        {% if milestone.getActivityId() %}
                            {% set activity = enrichedActivities.find(milestone.getActivityId()) %}
                            {{ activity|activityLink }}
                        {% endif %}
                    </div>
                    {% if milestone.getFunComparison() %}
                        <div class="mt-1 text-sm italic text-gray-500">
                            {{ milestone.getFunComparison()|trans }}
                        </div>
                    {% endif %}
                    {% if milestone.getCategory() == enum('App\\Domain\\Milestone\\MilestoneCategory').EDDINGTON  %}
                        <div class="mt-1 text-sm italic text-gray-500">
                            {{ "That's {number} days of at least {distance}"|trans({
                                '{number}': milestone.getContext().getNumber(),
                                '{distance}':  milestone.getContext().getDistance()|renderMeasurement(0)})|raw
                            }}
                        </div>
                    {% endif %}
                    {% if milestone.getPrevious() %}
                        <div class="mt-1 text-xs text-gray-400">
                            {{ "Previous"|trans }}:
                            <a href="javascript:void(0)" data-scroll-to="{{ milestone.getPrevious().getMilestoneId() }}" class="underline hover:text-gray-600">{{ milestone.getPrevious().getLabel() }}</a>
                            {{ "on"|trans }} {{ milestone.getPrevious().getAchievedOn()|formatDate('normal') }}
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
{% macro milestoneTitle(milestone) %}
    {% set context = milestone.getContext() %}
    {% set category = milestone.getCategory().value %}

    {% if category == 'first' %}
        {{ "First-ever activity recorded"|trans }}
    {% elseif category == 'activityCount' %}
        {{ "Completed {threshold} activities"|trans({'{threshold}': context.getThreshold()|formatNumber(0)}) }}
    {% elseif category == 'cumulativeDistance' %}
        {{ "Reached {threshold} total distance"|trans({'{threshold}': context.getThreshold()|renderMeasurement(0)})|raw }}
    {% elseif category == 'cumulativeElevation' %}
        {{ "Reached {threshold} total elevation"|trans({'{threshold}': context.getThreshold()|renderMeasurement(0)})|raw }}
    {% elseif category == 'cumulativeMovingTime' %}
        {{ "Reached {threshold} hours total moving time"|trans({'{threshold}': context.getThreshold().toFloat()|formatNumber(0)})|raw }}
    {% elseif category == 'activityDistance' %}
        {{ "Longest distance"|trans }}: {{ context.getValue()|renderMeasurement(1)|raw }}
    {% elseif category == 'activityElevation' %}
        {{ "Most elevation"|trans }}: {{ context.getValue()|renderMeasurement(0)|raw }}
    {% elseif category == 'activityMovingTime' %}
        {{ "Longest activity"|trans }}: {{ context.getValue()|formatSeconds }}
    {% elseif category == 'personalBest' %}
        {{ "New personal best for"|trans }} {{ context.getDistance()|renderMeasurement(0)|raw }}: {{ context.getTime()|formatSeconds }}
    {% elseif category == 'eddington' %}
        {{ context.getLabel() }}: {{ "reached Eddington number {number}"|trans({'{number}': context.getNumber()}) }}
    {% elseif category == 'streak' %}
        {{ "{days} consecutive days of activity"|trans({'{days}': context.getDays()}) }}
    {% elseif category == 'gearDistance' %}
        {{ "{threshold} on {gearName}"|trans({
            '{threshold}': context.getThreshold()|renderMeasurement(0),
            '{gearName}': context.getGearName()
        })|raw }}
    {% elseif category == 'gearElevation' %}
        {{ "{threshold} on {gearName}"|trans({
            '{threshold}': context.getThreshold()|renderMeasurement(0),
            '{gearName}': context.getGearName()
        })|raw }}
    {% elseif category == 'gearMovingTime' %}
        {{ "{threshold} hours on {gearName}"|trans({
            '{threshold}': context.getThreshold().toFloat()|formatNumber(0),
            '{gearName}': context.getGearName()
        })|raw }}
    {% endif %}
{% endmacro %}