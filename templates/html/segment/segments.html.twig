{% include 'html/navigation/breadcrumbs.html.twig' with {'breadcrumbs': [{
    'url': 'segments',
    'label': 'Segments'|trans
}]} %}
{% autoescape false %}
    <div class="grid grid-cols-1 gap-4">
        <!-- SEGMENTS -->
        <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs">
            <div data-dataTable-settings='{"url":"{{ relativeUrl('api/segment/data-table.json') }}","name":"segments"}' class="relative">
                <form class="flex flex-col gap-y-2 mb-2" autocomplete="off">
                    <div class="flex items-center">
                        <label for="search" class="sr-only">{{ "Search"|trans }}</label>
                        <div class="relative w-full">
                            <div class="absolute inset-y-0 start-0 flex items-center ps-3 pointer-events-none">
                                <svg class="w-4 h-4 text-gray-500" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 20">
                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 19-4-4m0-7A7 7 0 1 1 1 8a7 7 0 0 1 14 0Z"/>
                                </svg>
                            </div>
                            <input id="search" type="search" placeholder="{{ "Search segment..."|trans }}" class="table-search bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full ps-10 p-2.5">
                        </div>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        {% if sportTypes|length > 0 %}
                            <div class="filter-dropdown">
                                <button id="dropdownSportTypesButton"
                                        data-dropdown-toggle="dropdownSportTypes" data-dropdown-offset-distance="10" data-dropdown-offset-skidding="0" type="button">
                                    <span>{{ "Filter on sport type"|trans }}</span>
                                    <svg class="w-2.5 h-2.5 ms-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
                                    </svg>
                                </button>
                                <div id="dropdownSportTypes" class="divide-y divide-gray-100">
                                    <ul aria-labelledby="dropdownSportTypesButton">
                                        {% for sportType in sportTypes %}
                                            <li>
                                                <div>
                                                    <input type="checkbox" id="{{ sportType.value }}" data-dataTable-filter="sportType" name="sportType[{{ sportType.value }}]" value="{{ sportType.value }}" class="peer" />
                                                    <label for="{{ sportType.value }}" class="flex gap-x-1 items-center">
                                                        {{ svgSportType(sportType) }}
                                                        <div>{{ sportType|trans }}</div>
                                                    </label>
                                                    <a href="#" data-datatable-filter-clear="sportType[{{ sportType.value }}]">{{ "clear"|trans }}</a>
                                                </div>
                                            </li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            </div>
                        {% endif %}
                        {% if countries|length > 0 %}
                            <div class="filter-dropdown">
                                <button id="dropdownCountriesButton"
                                        data-dropdown-toggle="dropdownCountries" data-dropdown-offset-distance="10" data-dropdown-offset-skidding="0" type="button">
                                    <span>{{ "Country"|trans }}</span>
                                    <svg class="w-2.5 h-2.5 ms-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
                                    </svg>
                                </button>
                                <div id="dropdownCountries" class="divide-y divide-gray-100">
                                    <ul aria-labelledby="dropdownCountriesButton">
                                        {% for countryCode,countryName in countries %}
                                            <li>
                                                <div>
                                                    <input type="radio" id="{{ countryCode }}" data-dataTable-filter="countryCode" name="countryCode" value="{{ countryCode }}" class="peer" />
                                                    <label for="{{ countryCode }}" class="flex gap-x-1 items-center">
                                                        <img src="{{ countryCode|countryIcon }}" width="15" class="rounded-xs" title="{{ countryName }}" alt="{{ countryName }}">
                                                        <span>{{ countryName }}</span>
                                                    </label>
                                                    <a href="#" data-datatable-filter-clear="countryCode">{{ "clear"|trans }}</a>
                                                </div>
                                            </li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            </div>
                        {% endif %}
                        <div class="filter-dropdown">
                            <button id="distanceButton" data-dropdown-toggle="dropdownDistance" data-dropdown-offset-distance="10" data-dropdown-offset-skidding="0" type="button">
                                <span>{{ "Distance"|trans }}</span>
                                <svg class="w-2.5 h-2.5 ms-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
                                </svg>
                            </button>
                            <div id="dropdownDistance">
                                <div class="p-3 flex flex-col gap-y-2">
                                    <div class="flex flex-col gap-y-2">
                                        <label for="distance[from]" class="flex gap-x-1 items-center text-sm font-medium text-gray-500">
                                            {{ svg('distance', 'size-4', 'text-gray-500') }}
                                            <span>{{ "Distance"|trans }}</span>
                                        </label>
                                        <div class="group/range-filter flex items-center justify-between gap-x-2">
                                            <div class="flex items-center justify-between w-full" data-dataTable-filter="distance[]">
                                                <div class="flex items-center">
                                                    <input name="distance[from]" type="number" min="0" step="0.1" placeholder="{{ "min"|trans }}" class="z-20 w-23 bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-s-lg focus:ring-blue-500 focus:border-blue-500 block p-2.5">
                                                    <span class="flex items-center py-3 px-3 bg-gray-100 text-gray-500 border border-l-0 border-gray-300 text-xs rounded-e-lg">
                                                      {{ renderUnitSymbol('distance') }}
                                                    </span>
                                                </div>
                                                <span class="mx-2 text-gray-500">{{ "to"|trans }}</span>
                                                <div class="flex items-center">
                                                    <input name="distance[to]" type="number" min="0" step="0.1" placeholder="{{ "max"|trans }}" class="z-20 w-23 bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-s-lg focus:ring-blue-500 focus:border-blue-500 block p-2.5">
                                                    <span class="flex items-center py-3 px-3 bg-gray-100 text-gray-500 border border-l-0 border-gray-300 text-xs rounded-e-lg">
                                                      {{ renderUnitSymbol('distance') }}
                                                    </span>
                                                </div>
                                            </div>
                                            <a href="#" class="invisible group-has-[input:not(:placeholder-shown)]/range-filter:visible text-strava-orange text-sm text-right underline" data-datatable-filter-clear="distance">{{ "clear"|trans }}</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="filter-dropdown">
                            <button id="gradientButton" data-dropdown-toggle="dropdownGradient" data-dropdown-offset-distance="10" data-dropdown-offset-skidding="0" type="button">
                                <span>{{ "Gradient"|trans }}</span>
                                <svg class="w-2.5 h-2.5 ms-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
                                </svg>
                            </button>
                            <div id="dropdownGradient">
                                <div class="p-3 flex flex-col gap-y-2">
                                    <div class="flex flex-col gap-y-2">
                                        <label for="averageGradient[from]" class="flex gap-x-1 items-center text-sm font-medium text-gray-500">
                                            {{ svg('percentage', 'size-4', 'text-gray-500') }}
                                            <span>{{ "Average gradient"|trans }}</span>
                                        </label>
                                        <div class="group/range-filter flex items-center justify-between gap-x-2">
                                            <div class="flex items-center justify-between w-full" data-dataTable-filter="averageGradient[]">
                                                <div class="flex items-center">
                                                    <input name="averageGradient[from]" type="number" step="0.1" placeholder="{{ "min"|trans }}" class="z-20 w-23 bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-s-lg focus:ring-blue-500 focus:border-blue-500 block p-2.5">
                                                    <span class="flex items-center py-3 px-3 bg-gray-100 text-gray-500 border border-l-0 border-gray-300 text-xs rounded-e-lg">
                                                      %
                                                    </span>
                                                </div>
                                                <span class="mx-2 text-gray-500">{{ "to"|trans }}</span>
                                                <div class="flex items-center">
                                                    <input name="averageGradient[to]" type="number" step="0.1" placeholder="{{ "max"|trans }}" class="z-20 w-23 bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-s-lg focus:ring-blue-500 focus:border-blue-500 block p-2.5">
                                                    <span class="flex items-center py-3 px-3 bg-gray-100 text-gray-500 border border-l-0 border-gray-300 text-xs rounded-e-lg">
                                                      %
                                                    </span>
                                                </div>
                                            </div>
                                            <a href="#" class="invisible group-has-[input:not(:placeholder-shown)]/range-filter:visible text-strava-orange text-sm text-right underline" data-datatable-filter-clear="averageGradient">{{ "clear"|trans }}</a>
                                        </div>
                                    </div>
                                    <div class="flex flex-col gap-y-2">
                                        <label for="maxGradient[from]" class="flex gap-x-1 items-center text-sm font-medium text-gray-500">
                                            {{ svg('percentage', 'size-4', 'text-gray-500') }}
                                            <span>{{ "Max gradient"|trans }}</span>
                                        </label>
                                        <div class="group/range-filter flex items-center justify-between gap-x-2">
                                            <div class="flex items-center justify-between w-full" data-dataTable-filter="maxGradient[]">
                                                <div class="flex items-center">
                                                    <input name="maxGradient[from]" type="number" step="0.1" placeholder="{{ "min"|trans }}" class="z-20 w-23 bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-s-lg focus:ring-blue-500 focus:border-blue-500 block p-2.5">
                                                    <span class="flex items-center py-3 px-3 bg-gray-100 text-gray-500 border border-l-0 border-gray-300 text-xs rounded-e-lg">
                                                      %
                                                    </span>
                                                </div>
                                                <span class="mx-2 text-gray-500">{{ "to"|trans }}</span>
                                                <div class="flex items-center">
                                                    <input name="maxGradient[to]" type="number" step="0.1" placeholder="{{ "max"|trans }}" class="z-20 w-23 bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-s-lg focus:ring-blue-500 focus:border-blue-500 block p-2.5">
                                                    <span class="flex items-center py-3 px-3 bg-gray-100 text-gray-500 border border-l-0 border-gray-300 text-xs rounded-e-lg">
                                                      %
                                                    </span>
                                                </div>
                                            </div>
                                            <a href="#" class="invisible group-has-[input:not(:placeholder-shown)]/range-filter:visible text-strava-orange text-sm text-right underline" data-datatable-filter-clear="maxGradient">{{ "clear"|trans }}</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="filter-dropdown">
                            <button id="dropdownDateRangeButton"
                                    data-dropdown-toggle="dropdownDateRange" type="button">
                                <span>{{ "Last effort date"|trans }}</span>
                                <svg class="w-2.5 h-2.5 ms-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
                                </svg>
                            </button>
                            <div id="dropdownDateRange" class="divide-y divide-gray-100">
                                <div class="flex items-center gap-x-2 p-3" aria-labelledby="dropdownDateRangeButton">
                                    <div class="flex items-center" data-dataTable-filter="lastEffortDate[]">
                                        <input name="lastEffortDate[from]" type="date" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5">
                                        <span class="mx-2 text-gray-500">{{ "to"|trans }}</span>
                                        <input name="lastEffortDate[to]" type="date" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5">
                                    </div>
                                    <a href="#" class="text-strava-orange text-sm text-right underline" data-datatable-filter-clear="lastEffortDate">{{ "clear"|trans }}</a>
                                </div>
                            </div>
                        </div>
                        <div class="filter-dropdown">
                            <button id="dropdownOtherButton"
                                    data-dropdown-toggle="dropdownOther" data-dropdown-offset-distance="10" data-dropdown-offset-skidding="0" type="button">
                                <span>{{ "Other"|trans }}</span>
                                <svg class="w-2.5 h-2.5 ms-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
                                </svg>
                            </button>
                            <div id="dropdownOther" class="divide-y divide-gray-100">
                                <ul aria-labelledby="dropdownOtherButton">
                                    <li>
                                        <div>
                                            <input type="checkbox" id="isFavourite" data-dataTable-filter="isFavourite" name="isFavourite" value="isFavourite" class="peer" />
                                            <label for="isFavourite" class="w-full peer-checked:border-strava-orange">
                                                    <span class="flex gap-x-1 items-center">
                                                        {{ svg('star') }}
                                                        <div>{{ "Favourite"|trans }}</div>
                                                    </span>
                                                <span class="text-xs font-normal text-gray-500">{{ "Filter on starred segments"|trans }}</span>
                                            </label>
                                        </div>
                                    </li>
                                    <li>
                                        <div>
                                            <input type="checkbox" id="isKom" data-dataTable-filter="isKom" name="isKom" value="isKom" class="peer" />
                                            <label for="isKom" class="w-full peer-checked:border-strava-orange">
                                                    <span class="flex gap-x-1 items-center">
                                                        {{ svg('elevation', 'h-4 shrink-0') }}
                                                        <div>{{ "KOM"|trans }}</div>
                                                    </span>
                                                <span class="text-xs font-normal text-gray-500">{{ "Filter on KOM segments"|trans }}</span>
                                            </label>
                                        </div>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="text-xs text-gray-700">
                        {% set numberOfResults = '<span class="font-bold" data-dataTable-result-count>' ~ totalSegmentCount ~ '</span>' %}
                        {{ "{numberOfResults} results based on your active filters"|trans({'{numberOfResults}': numberOfResults}) }}
                        <a href="#" class="hidden text-strava-orange underline" data-dataTable-reset>{{ "clear"|trans }}</a>
                    </div>
                </form>
                <div class="scroll-area overflow-auto max-h-[calc(100vh-285px)]">
                    <table class="w-full text-sm text-center text-gray-500">
                        <thead class="z-10 sticky top-0 text-xs text-gray-700 uppercase bg-gray-50">
                        <tr>
                            <th scope="col" data-dataTable-sort="name" class="px-2 py-3 cursor-pointer">
                                <div class="w-92">{{ svg('sorting-icon') }}</div>
                            </th>
                            <th scope="col" data-dataTable-sort="last-effort-date" class="px-2 py-3 cursor-pointer">
                                <div class="flex items-center justify-center" title="{{ "Last effort"|trans }}">
                                    {{ svg('calendar') }}
                                    {{ svg('sorting-icon') }}
                                </div>
                            </th>
                            <th scope="col" class="px-2 py-3">
                                <div class="flex items-center justify-center" title="{{ "Best effort"|trans }}">
                                    {{ svg('trophy') }}
                                </div>
                            </th>
                            <th scope="col" data-dataTable-sort="distance" class="px-2 py-3 cursor-pointer" title="{{ "Distance"|trans }}">
                                <div class="flex items-center justify-center">
                                    {{ svg('distance') }}
                                    {{ svg('sorting-icon') }}
                                </div>
                            </th>
                            <th scope="col" data-dataTable-sort="average-gradient" class="px-2 py-3 cursor-pointer" title="{{ "Average gradient"|trans }}">
                                <div class="flex items-center justify-center">
                                    {{ svg('percentage') }}
                                    {{ svg('sorting-icon') }}
                                </div>
                            </th>
                            <th scope="col" data-dataTable-sort="ride-count" class="px-2 py-3 cursor-pointer" title="{{ "Number of times completed"|trans }}">
                                <div class="flex items-center justify-center">
                                    {{ svg('hashtag') }}
                                    {{ svg('sorting-icon') }}
                                </div>
                            </th>
                        </tr>
                        </thead>
                        <tbody class="clusterize-content">
                        <tr class="clusterize-loading">
                            <td class="px-6 py-2 truncate">{{ "Loading data..."|trans }}</td>
                        </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endautoescape %}