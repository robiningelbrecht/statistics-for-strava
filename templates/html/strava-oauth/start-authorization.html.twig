{% autoescape false %}
<!DOCTYPE html>
<html lang="en">
<head>
    <title>{{ appName }}</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width">
    <meta name="theme-color" content="#F26822">
    <meta name="mobile-web-app-title" content="{{ appName }}">
    <meta name="mobile-web-app-capable" content="yes">
    <link rel="icon" type="image/x-icon" href="{{ relativeUrl('assets/images/logo.svg') }}">
    <link href="{{ relativeUrl(asset('css/dist/tailwind.min.css')) }}" rel="stylesheet"/>
</head>
<body class="min-h-screen bg-white text-gray-900 antialiased">
{% include 'html/navigation/top-nav-bar.html.twig' %}
<section class="flex min-h-screen flex-col justify-center px-6 py-12 sm:px-12">
    <div class="mx-auto w-full max-w-xl">
        <h2 class="mt-4 text-2xl font-bold tracking-tight">Connect your Strava account</h2>
        <p class="mt-1 text-sm text-gray-500">You haven't completed the Strava authorization yet. We'll redirect you to Strava. Just click <strong>Authorize</strong> when the page loads.</p>
        <a href="http://www.strava.com/oauth/authorize?client_id={{ stravaClientId }}&response_type=code&redirect_uri={{ returnUrl }}&approval_prompt=force&scope=activity:read_all"
           class="mt-6 inline-flex w-full items-center justify-center gap-2.5 rounded-xl bg-primary px-5 py-3 font-semibold text-white shadow-sm transition hover:brightness-95">
            <svg class="size-5" fill="currentColor" viewBox="0 0 24 24"><path d="M15.387 17.944l-2.089-4.116h-3.065L15.387 24l5.15-10.172h-3.066m-7.008-5.599l2.836 5.598h4.172L10.463 0l-7 13.828h4.169"/></svg>
            Connect with Strava
        </a>
        <p class="mt-2.5 flex items-center gap-1.5 text-xs text-gray-400">
            <svg class="size-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
            We only request the <code class="font-mono text-[11px]">activity:read_all</code> scope.
        </p>
        {% if error %}
            <div class="mt-6 overflow-hidden rounded-xl border border-red-200 bg-red-50">
                <div class="border-b border-red-200 bg-red-100/60 px-4 py-2 text-xs font-semibold uppercase tracking-wide text-red-700">Error details</div>
                <p class="px-4 py-3 font-mono text-sm text-red-800">{{ error }}</p>
            </div>
            <p class="mt-2.5 text-xs text-gray-500">
                Stuck? Check the <a class="font-medium text-primary hover:underline" href="https://docs.getsfs.app/#/troubleshooting/strava-authorization">troubleshooting guide</a>.
            </p>
        {% endif %}
    </div>
</section>
</body>
</html>
{% endautoescape %}